import fly.compiler.ast.ASTVar
import fly.data.List

public class ASTAttribute : ASTVar {

    public ASTAttribute(const SourceLocation loc, const ASTType type, const string name, const fly.data.List modifiers) {
        super(loc, type, name, modifiers)
    }
}
