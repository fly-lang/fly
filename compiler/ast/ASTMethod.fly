namespace fly.compiler.ast

import fly.compiler.basic.SourceLocation
import fly.compiler.ast.ASTFunction
import fly.compiler.ast.ASTFunctionKind
import fly.data.List

public class ASTMethod : ASTFunction {

    public ASTMethod(const SourceLocation loc, const fly.data.List modifiers, const string name, const fly.data.List params) {
        super(loc, modifiers, name, params, ASTFunctionKind.F_METHOD)
    }
}
