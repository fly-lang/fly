namespace fly.compiler.target
import fly.compiler.target.*

// BPF — eBPF, 64-bit, little- and big-endian. clang-verified LLVM-20 layouts.
// Reduced port of fly/compiler/Basic/Targets/BPF.*.

public void bpfelPopulate(const TargetInfo ti) {
    ti.applyData("e-m:e-p:64:64-i64:64-i128:128-n32:64-S128", 64, false, 32, 64)
}

public void bpfebPopulate(const TargetInfo ti) {
    ti.applyData("E-m:e-p:64:64-i64:64-i128:128-n32:64-S128", 64, true, 32, 64)
}
