namespace fly.compiler.target
import fly.compiler.target.*

// AVR — 8-bit MCU with 16-bit pointers (int is 16-bit). clang-verified LLVM-20
// layout. Reduced port of fly/compiler/Basic/Targets/AVR.*.

public void avrPopulate(const TargetInfo ti) {
    ti.applyData("e-P1-p:16:8-i8:8-i16:8-i32:8-i64:8-f32:8-f64:8-n8-a:8", 16, false, 16, 32)
}
