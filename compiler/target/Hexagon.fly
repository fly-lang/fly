namespace fly.compiler.target
import fly.compiler.target.*

// Hexagon — Qualcomm DSP, 32-bit. clang-verified LLVM-20 layout.
// Reduced port of fly/compiler/Basic/Targets/Hexagon.*.

public void hexagonPopulate(const TargetInfo ti) {
    ti.applyData("e-m:e-p:32:32:32-a:0-n16:32-i64:64:64-i32:32:32-i16:16:16-i1:8:8-f32:32:32-f64:64:64-v32:32:32-v64:64:64-v512:512:512-v1024:1024:1024-v2048:2048:2048", 32, false, 32, 32)
}
