namespace fly.compiler.target
import fly.compiler.target.*

// NVPTX — NVIDIA PTX, 32/64-bit. clang-verified LLVM-20 layouts.
// Reduced port of fly/compiler/Basic/Targets/NVPTX.*.

public void nvptxPopulate(const TargetInfo ti) {
    ti.applyData("e-p:32:32-p6:32:32-p7:32:32-i64:64-i128:128-v16:16-v32:32-n16:32:64", 32, false, 32, 32)
}

public void nvptx64Populate(const TargetInfo ti) {
    ti.applyData("e-p6:32:32-i64:64-i128:128-v16:16-v32:32-n16:32:64", 64, false, 32, 64)
}
