    // ── Context ───────────────────────────────────────────────────────────────

    public void contextCreate(fly.mem.Ptr ctx) {
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMContextCreate", new NoArgs(), ctx)
    }

    public void contextDispose(const fly.mem.Ptr ctx) {
        Ptr1Args a = new Ptr1Args()
        a.a = ctx
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMContextDispose", a)
    }

    public void getGlobalContext(fly.mem.Ptr ctx) {
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMGetGlobalContext", new NoArgs(), ctx)
    }

    // ── Module ────────────────────────────────────────────────────────────────

    public void moduleCreateWithNameInContext(const string name, const fly.mem.Ptr ctx, fly.mem.Ptr mod) {
        StrPtrArgs a = new StrPtrArgs()
        a.s = name
        a.a = ctx
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMModuleCreateWithNameInContext", a, mod)
    }

    public void disposeModule(const fly.mem.Ptr mod) {
        Ptr1Args a = new Ptr1Args()
        a.a = mod
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMDisposeModule", a)
    }

    public void setDataLayout(const fly.mem.Ptr mod, const string layout) {
        Ptr2Args a = new Ptr2Args()
        a.a = mod
        a.b = fly.mem.toPtr(cbuf(layout))
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMSetDataLayout", a)
    }

    public void setTarget(const fly.mem.Ptr mod, const string triple) {
        Ptr2Args a = new Ptr2Args()
        a.a = mod
        a.b = fly.mem.toPtr(cbuf(triple))
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMSetTarget", a)
    }

    public void printModuleToFile(const fly.mem.Ptr mod, const string filename) {
        PtrStrArgs a = new PtrStrArgs()
        a.a = mod
        a.s = filename
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMPrintModuleToFile", a)
    }

    public void writeBitcodeToFile(const fly.mem.Ptr mod, const string path) {
        PtrStrArgs a = new PtrStrArgs()
        a.a = mod
        a.s = path
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMWriteBitcodeToFile", a)
    }

    public void verifyModule(const fly.mem.Ptr mod, bool ok) {
        // LLVMVerifyModule(M, LLVMReturnStatusAction=2, NULL) returns 1=broken, 0=valid.
        // Negate to get the "is valid" semantics expected by callers.
        PtrIntPtrArgs vargs = new PtrIntPtrArgs()
        vargs.a = mod
        vargs.n = 2
        vargs.b = fly.mem.toPtr(0)
        CLang lib = new CLang("libLLVM-20.so")
        bool broken = false
        lib.call("LLVMVerifyModule", vargs, broken)
        if broken == false { ok = true } else { ok = false }
    }

