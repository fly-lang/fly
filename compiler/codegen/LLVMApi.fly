    public void constInt(const fly.mem.Ptr intTy, const long val, const bool signExtend, fly.mem.Ptr v) {
        // LLVMConstInt(IntTy, N, SignExtend) = (ptr, long, int)
        PtrLongIntArgs a = new PtrLongIntArgs()
        a.a = intTy
        a.n = val
        a.p = 0
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMConstInt", a, v)
    }

    public void constReal(const fly.mem.Ptr realTy, const double val, fly.mem.Ptr v) {
        // LLVMConstReal(RealTy, N) = (ptr, double)
        PtrDoubleArgs a = new PtrDoubleArgs()
        a.a = realTy
        a.d = val
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMConstReal", a, v)
    }

    public void constNull(const fly.mem.Ptr ty, fly.mem.Ptr v) {
        Ptr1Args a = new Ptr1Args()
        a.a = ty
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMConstNull", a, v)
    }

    public void constPointerNull(const fly.mem.Ptr ty, fly.mem.Ptr v) {
        Ptr1Args a = new Ptr1Args()
        a.a = ty
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMConstPointerNull", a, v)
    }

    public void constStringInContext(const fly.mem.Ptr ctx, const string str, const int length, const bool nullTerminated, fly.mem.Ptr v) {
        // LLVMConstStringInContext(Ctx, Str, Length, DontNullTerminate). Length is
        // explicit (Fly strings aren't null-terminated C strings); DontNull=0 ADDS a
        // terminator. The old 1-int variant dropped Length → empty [0 x i8].
        PtrStrIntIntArgs a = new PtrStrIntIntArgs()
        a.a = ctx
        a.s = str
        a.n = length
        if nullTerminated { a.m = 0 } else { a.m = 1 }
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMConstStringInContext", a, v)
    }

    public void constStructInContext(const fly.mem.Ptr ctx, const fly.mem.Ptr vals, const int numVals, const bool packed, fly.mem.Ptr v) {
        PtrPtrIntArgs a = new PtrPtrIntArgs()
        a.a = ctx
        a.b = vals
        a.n = numVals
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMConstStructInContext", a, v)
    }

    public void constArray(const fly.mem.Ptr elemTy, const fly.mem.Ptr vals, const int numVals, fly.mem.Ptr v) {
        PtrPtrIntArgs a = new PtrPtrIntArgs()
        a.a = elemTy
        a.b = vals
        a.n = numVals
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMConstArray", a, v)
    }

    // constNamedStruct — LLVMConstNamedStruct(StructTy, ConstantVals, Count): a
    // constant of a NAMED struct type (unlike LLVMConstStruct which makes an
    // anonymous literal-struct constant that wouldn't match a %name alloca).
    public void constNamedStruct(const fly.mem.Ptr structTy, const fly.mem.Ptr vals, const int numVals, fly.mem.Ptr v) {
        PtrPtrIntArgs a = new PtrPtrIntArgs()
        a.a = structTy
        a.b = vals
        a.n = numVals
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMConstNamedStruct", a, v)
    }

    // ── Global variables ──────────────────────────────────────────────────────

    public void addGlobal(const fly.mem.Ptr mod, const fly.mem.Ptr ty, const string name, fly.mem.Ptr v) {
        // LLVMAddGlobal(M, Ty, Name) = (ptr, ptr, string)
        Ptr2StrArgs a = new Ptr2StrArgs()
        a.a = mod
        a.b = ty
        a.s = name
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMAddGlobal", a, v)
    }

    public void getNamedGlobal(const fly.mem.Ptr mod, const string name, fly.mem.Ptr v) {
        PtrStrArgs a = new PtrStrArgs()
        a.a = mod
        a.s = name
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMGetNamedGlobal", a, v)
    }

    public void setInitializer(const fly.mem.Ptr global, const fly.mem.Ptr val) {
        Ptr2Args a = new Ptr2Args()
        a.a = global
        a.b = val
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMSetInitializer", a)
    }

    public void setGlobalConstant(const fly.mem.Ptr global, const bool isConst) {
        PtrIntArgs a = new PtrIntArgs()
        a.a = global
        if isConst { a.n = 1 } else { a.n = 0 }
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMSetGlobalConstant", a)
    }

    // ── Target machine ────────────────────────────────────────────────────────

    public void getDefaultTargetTriple(fly.mem.Ptr triple) {
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMGetDefaultTargetTriple", new NoArgs(), triple)
    }

    // getTargetFromTriple — look up the LLVMTargetRef for `triple`. The C function
    // writes the target through a `LLVMTargetRef*` out-pointer and returns a status
    // (0 = success). We give it an 8-byte buffer (via the Ptr-buffer idiom) for the
    // out-pointer, then copy the written value into `target.addr`. `ok` carries the
    // raw LLVMBool return (true = FAILURE); callers should test `target.addr != 0`.
    public void getTargetFromTriple(const string triple, fly.mem.Ptr target, bool ok) {
        long buf = fly.mem.alloc(8)
        fly.mem.writeLong(buf, 0, 0)
        Ptr3Args a = new Ptr3Args()
        a.a = fly.mem.toPtr(cbuf(triple))   // const char* Triple (NUL-terminated)
        a.b = fly.mem.toPtr(buf)            // LLVMTargetRef* T  (out-pointer buffer)
        // a.c stays null → char** Err = NULL
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMGetTargetFromTriple", a, ok)
        target.addr = fly.mem.readLong(buf, 0)
        fly.mem.free(buf, 8)
    }

    // createTargetMachine — full 7-argument marshalling (the old stub dropped all
    // but `target`). The TM pointer is the C return value, captured into `tm`.
    public void createTargetMachine(const fly.mem.Ptr target, const string triple, const string cpu, const string features, const int optLevel, const int reloc, const int codeModel, fly.mem.Ptr tm) {
        CreateTMArgs a = new CreateTMArgs()
        a.target = target
        a.triple = fly.mem.toPtr(cbuf(triple))
        a.cpu = fly.mem.toPtr(cbuf(cpu))
        a.features = fly.mem.toPtr(cbuf(features))
        a.level = optLevel
        a.reloc = reloc
        a.codeModel = codeModel
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMCreateTargetMachine", a, tm)
    }

    public void disposeTargetMachine(const fly.mem.Ptr tm) {
        Ptr1Args a = new Ptr1Args()
        a.a = tm
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMDisposeTargetMachine", a)
    }

    public void createTargetDataLayout(const fly.mem.Ptr tm, fly.mem.Ptr dl) {
        Ptr1Args a = new Ptr1Args()
        a.a = tm
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMCreateTargetDataLayout", a, dl)
    }

    public void setModuleDataLayout(const fly.mem.Ptr mod, const fly.mem.Ptr dl) {
        Ptr2Args a = new Ptr2Args()
        a.a = mod
        a.b = dl
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMSetModuleDataLayout", a)
    }

    // targetMachineEmitToFile — emit `mod` to `filename` (emitType 0=assembly,
    // 1=object). The old stub dropped `filename`; this passes all four args plus a
    // null `char** ErrorMessage`. `ok` is the raw LLVMBool return (true = FAILURE).
    public void targetMachineEmitToFile(const fly.mem.Ptr tm, const fly.mem.Ptr mod, const string filename, const int emitType, bool ok) {
        EmitFileArgs a = new EmitFileArgs()
        a.tm = tm
        a.mod = mod
        a.filename = fly.mem.toPtr(cbuf(filename))
        a.emitType = emitType
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMTargetMachineEmitToFile", a, ok)
    }

