    public void buildAlloca(const fly.mem.Ptr b, const fly.mem.Ptr ty, const string name, fly.mem.Ptr v) {
        // LLVMBuildAlloca(B, Ty, Name) = (ptr, ptr, string)
        Ptr2StrArgs a = new Ptr2StrArgs()
        a.a = b
        a.b = ty
        a.s = name
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMBuildAlloca", a, v)
    }

    public void buildLoad2(const fly.mem.Ptr b, const fly.mem.Ptr ty, const fly.mem.Ptr ptr, const string name, fly.mem.Ptr v) {
        // LLVMBuildLoad2(B, Ty, Ptr, Name) = (ptr, ptr, ptr, string) → use Ptr3 + store name in 4th
        // We use Ptr3Args which gives [b, ty, ptr] as C args 0-2; name (4th arg) is missing but LLVM accepts "" gracefully.
        Ptr3StrArgs a = new Ptr3StrArgs()
        a.a = b
        a.b = ty
        a.c = ptr
        a.s = name
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMBuildLoad2", a, v)
    }

    public void buildStore(const fly.mem.Ptr b, const fly.mem.Ptr val, const fly.mem.Ptr ptr) {
        Ptr3Args a = new Ptr3Args()
