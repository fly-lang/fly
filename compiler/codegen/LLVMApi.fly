        a.b = val
        a.c = ptr
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMBuildStore", a)
    }

    public void buildGEP2(const fly.mem.Ptr b, const fly.mem.Ptr ty, const fly.mem.Ptr ptr, const fly.mem.Ptr indices, const int numIndices, const string name, fly.mem.Ptr v) {
        // LLVMBuildGEP2(B, Ty, Ptr, Indices, NumIndices, Name) — must pass NumIndices
        // and Name (the old Ptr4Args dropped them → garbage index-count + name).
        Ptr4IntStrArgs a = new Ptr4IntStrArgs()
        a.a = b
        a.b = ty
        a.c = ptr
        a.d = indices
        a.n = numIndices
        a.s = name
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMBuildGEP2", a, v)
    }

    // buildMalloc — LLVMBuildMalloc(B, Ty, Name): allocates sizeof(Ty) on the heap
    // (LLVM computes the size + auto-declares @malloc) and returns the typed ptr.
    public void buildMalloc(const fly.mem.Ptr b, const fly.mem.Ptr ty, const string name, fly.mem.Ptr v) {
        Ptr2StrArgs a = new Ptr2StrArgs()
        a.a = b
        a.b = ty
