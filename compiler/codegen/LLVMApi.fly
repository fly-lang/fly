        // LLVMBuildStructGEP2(B, Ty, Pointer, Idx, Name) = (ptr, ptr, ptr, int, string)
        Ptr3IntStrArgs a = new Ptr3IntStrArgs()
        a.a = b
        a.b = ty
        a.c = ptr
        a.n = idx
        a.s = name
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMBuildStructGEP2", a, v)
    }

