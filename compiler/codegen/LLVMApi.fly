    // ── Basic blocks ──────────────────────────────────────────────────────────

    public void appendBasicBlockInContext(const fly.mem.Ptr ctx, const fly.mem.Ptr fn, const string name, fly.mem.Ptr bb) {
        // LLVMAppendBasicBlockInContext(C, Fn, Name) → needs [ptr, ptr, string] C arg order
        Ptr2StrArgs a = new Ptr2StrArgs()
        a.a = ctx
        a.b = fn
        a.s = name
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMAppendBasicBlockInContext", a, bb)
    }

    public void getInsertBlock(const fly.mem.Ptr builder, fly.mem.Ptr bb) {
        Ptr1Args a = new Ptr1Args()
        a.a = builder
