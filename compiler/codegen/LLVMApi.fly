namespace llvm.api

import fly.bridge.*
import fly.mem
import fly.runtime
import fly.str

// All LLVM handles are fly.mem.Ptr (opaque C pointer wrappers).
// On Linux: libLLVM-20.so   On Windows: LLVM-C.dll
// Instantiate LLVM once and reuse it across the compilation unit.

// cbuf — a raw, NUL-terminated byte buffer holding `s`, returned as its address.
//
// Fly strings are {ptr,len} and are NOT NUL-terminated; LLVM's `const char*`
// entry points call strlen and read past the end of a heap string, appending
// adjacent garbage (e.g. a stray '!' after a triple stored in a field). A Fly
// string can't carry the terminator either — assigning it into an Args field
// re-clones it into a len-byte buffer, dropping the NUL. So we emit a plain
// buffer and pass its ADDRESS as a Ptr arg (a long is never cloned), giving the C
// side a real, terminated C string. The buffer outlives the (synchronous) call;
// it leaks, which is fine for the one-shot compiler.
public long cbuf(const string s) {
    int n = fly.str.len(s)
    long buf = fly.mem.alloc(n + 1)
    byte b = 0
    int i = 0
    while i < n {
        fly.str.byteAt(s, i, b)
        fly.mem.writeByte(buf, i, b)
        i = i + 1
    }
    byte z = 0
    fly.mem.writeByte(buf, n, z)
    out = buf
}

// ── Argument structs ──────────────────────────────────────────────────────────

struct NoArgs  : Args {}

struct Ptr1Args : Args {
    fly.mem.Ptr a
}

struct Ptr2Args : Args {
    fly.mem.Ptr a
    fly.mem.Ptr b
}

struct Ptr3Args : Args {
    fly.mem.Ptr a
    fly.mem.Ptr b
    fly.mem.Ptr c
}

struct Ptr4Args : Args {
    fly.mem.Ptr a
    fly.mem.Ptr b
    fly.mem.Ptr c
    fly.mem.Ptr d
}

struct PtrStrArgs : Args {
    fly.mem.Ptr a
    string s
}

struct PtrStrPtrArgs : Args {
    fly.mem.Ptr a
    string s
    fly.mem.Ptr b
}

struct PtrIntArgs : Args {
    fly.mem.Ptr a
    int n
}

struct PtrLongArgs : Args {
    fly.mem.Ptr a
    long n
}

struct PtrPtrIntArgs : Args {
    fly.mem.Ptr a
    fly.mem.Ptr b
    int n
}

struct PtrPtrIntIntArgs : Args {
    fly.mem.Ptr a
    fly.mem.Ptr b
    int n
    int p
}

struct PtrPtrLongArgs : Args {
    fly.mem.Ptr a
    fly.mem.Ptr b
    long n
}

struct PtrIntPtr2StrArgs : Args {
    fly.mem.Ptr a
    int n
    fly.mem.Ptr b
    fly.mem.Ptr c
    string s
}

struct PtrIntPtrArgs : Args {
    fly.mem.Ptr a
    int n
    fly.mem.Ptr b
}

struct StrPtrArgs : Args {
    string s
    fly.mem.Ptr a
}

// Ptr2StrArgs: two ptr fields THEN a string — gives C args [a, b, s] = (ptr, ptr, string)
// Use for functions like LLVMAppendBasicBlockInContext(C, Fn, Name)
struct Ptr2StrArgs : Args {
    fly.mem.Ptr a
    fly.mem.Ptr b
    string s
}

// Ptr3StrArgs: three ptr fields then a string — gives C args [a, b, c, s] = (ptr, ptr, ptr, string)
// Use for functions like LLVMBuildAdd(B, LHS, RHS, Name)
struct Ptr3StrArgs : Args {
    fly.mem.Ptr a
    fly.mem.Ptr b
    fly.mem.Ptr c
    string s
}

struct Ptr3IntArgs : Args {
    fly.mem.Ptr a
    fly.mem.Ptr b
    fly.mem.Ptr c
    int n
}

struct Ptr3IntStrArgs : Args {
    fly.mem.Ptr a
    fly.mem.Ptr b
    fly.mem.Ptr c
    int n
    string s
}

// 4 ptrs + int + string, e.g. LLVMBuildCall2(B, FnTy, Fn, Args, NumArgs, Name)
// and LLVMBuildGEP2(B, Ty, Ptr, Indices, NumIndices, Name).
struct Ptr4IntStrArgs : Args {
    fly.mem.Ptr a
    fly.mem.Ptr b
    fly.mem.Ptr c
    fly.mem.Ptr d
    int n
    string s
}

struct StrArgs : Args {
    string s
}

struct StrStrArgs : Args {
    string a
    string b
}

struct IntArgs : Args {
    int n
}

struct LongArgs : Args {
    long n
}

struct PtrLongIntArgs : Args {
    fly.mem.Ptr a
    long n
    int p
}

struct PtrDoubleArgs : Args {
    fly.mem.Ptr a
    double d
}

// PtrStrIntArgs: ptr + string + int — gives C args (ptr, str_ptr, str_len, n).
// Used for functions like LLVMConstStringInContext where the 4th arg is an int flag.
struct PtrStrIntArgs : Args {
    fly.mem.Ptr a
    string s
    int n
}

// ptr + string + 2 ints, e.g. LLVMConstStringInContext(Ctx, Str, Length, DontNull)
struct PtrStrIntIntArgs : Args {
    fly.mem.Ptr a
    string s
    int n
    int m
}

// LLVMCreateTargetMachine(T, Triple, CPU, Features, Level, Reloc, CodeModel).
// Source field order == C argument order (the bridge marshals fields positionally).
// The three C strings are passed as Ptr-to-NUL-buffer (see cbuf) rather than Fly
// `string` fields, which would lose the terminator on assignment.
struct CreateTMArgs : Args {
    fly.mem.Ptr target
    fly.mem.Ptr triple
    fly.mem.Ptr cpu
    fly.mem.Ptr features
    int level
    int reloc
    int codeModel
}

// LLVMTargetMachineEmitToFile(TM, M, Filename, FileType, char** Err).
// `filename` is a Ptr-to-NUL-buffer; `err` stays null (char** NULL).
struct EmitFileArgs : Args {
    fly.mem.Ptr tm
    fly.mem.Ptr mod
    fly.mem.Ptr filename
    int emitType
    fly.mem.Ptr err
}

// ── LLVM wrapper ──────────────────────────────────────────────────────────────

public class LLVM {

    public LLVM() {
    }

    // ── Initialization ────────────────────────────────────────────────────────

    // Note: LLVMInitializeAll* are static inline wrappers not exported from libLLVM-20.so.
    // Use target-specific init functions instead (x86_64 is the primary bootstrap target).
    public void initializeAllTargetInfos() {
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMInitializeX86TargetInfo", new NoArgs())
    }

    public void initializeAllTargets() {
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMInitializeX86Target", new NoArgs())
    }

    public void initializeAllTargetMCs() {
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMInitializeX86TargetMC", new NoArgs())
    }

    public void initializeAllAsmParsers() {
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMInitializeX86AsmParser", new NoArgs())
    }

    public void initializeAllAsmPrinters() {
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMInitializeX86AsmPrinter", new NoArgs())
    }

    // ── Per-backend registration ───────────────────────────────────────────────
    //
    // Each registers a backend's TargetInfo + Target + TargetMC + AsmPrinter (the
    // set needed to look up a target and emit .o/.s). Only backends actually
    // present in libLLVM-20.so are wrapped — referencing a missing LLVMInitialize*
    // symbol would break linking. `initTargetForArch` (target/TargetInit.fly)
    // dispatches the right one per arch.

    public void initX86() {
        CLang lib = new CLang("libLLVM-20.so")
        lib.call("LLVMInitializeX86TargetInfo", new NoArgs())
        lib.call("LLVMInitializeX86Target", new NoArgs())
        lib.call("LLVMInitializeX86TargetMC", new NoArgs())
        lib.call("LLVMInitializeX86AsmPrinter", new NoArgs())
    }
