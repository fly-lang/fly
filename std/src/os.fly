public ioCopy(Reader src, Writer dst, long out_copied) {
    int chunk_sz = 8192
    long tmp = 0
    fly.runtime.mem_alloc(chunk_sz, tmp)
    long total = 0
    bool done = false
    while done == false {
        fly_buf chunk = new fly_buf()
        chunk.ptr = tmp
        chunk.size = 0
        ulong chunk_sz_u = chunk_sz
        chunk.cap = chunk_sz_u
        long nread = 0
        src.read(chunk, chunk_sz_u, nread)
        if nread == 0 {
            done = true
        } else {
            chunk.size = nread
            long nwritten = 0
            dst.write(chunk, chunk_sz_u, nwritten)
            total = total + nread
        }
    }
    out_copied = total
}

public ioCopyN(Reader src, Writer dst, const ulong n, long out_copied) {
    int chunk_sz = 8192
    long tmp = 0
    fly.runtime.mem_alloc(chunk_sz, tmp)
    long total = 0
    ulong remaining = n
    bool done = false
    while done == false {
        if remaining == 0 {
            done = true
        } else {
            ulong chunk_sz_u = chunk_sz
            ulong to_read = chunk_sz_u
            if remaining < to_read { to_read = remaining }
            fly_buf chunk = new fly_buf()
            chunk.ptr = tmp
            chunk.size = 0
            chunk.cap = to_read
            long nread = 0
            src.read(chunk, to_read, nread)
            if nread == 0 {
                done = true
            } else {
                chunk.size = nread
                long nwritten = 0
                dst.write(chunk, to_read, nwritten)
                total = total + nread
                ulong nread_u = nread
                remaining = remaining - nread_u
            }
        }
    }
    out_copied = total
}

public ioPipe(Reader pipe_r, Writer pipe_w) {
    long copied = 0
    ioCopy(pipe_r, pipe_w, copied)
}
