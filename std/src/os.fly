}

public fsCopy(const string src, const string dst) {
    long cpath_src = 0
    strToCstr(src, cpath_src)
    long fsize = 0
    fly.runtime.fs_size(cpath_src, fsize)
    if fsize < 0 { fsize = 0 }
    ulong write_size = fsize
    ulong alloc_size = fsize
    if alloc_size == 0 { alloc_size = 1 }
    long buf = 0
    fly.runtime.mem_alloc(alloc_size, buf)
    if fsize > 0 {
        int fd_src = 0
        fly.runtime.fs_open(cpath_src, 0, 0, fd_src)
        if fd_src >= 0 {
            long nread = 0
            fly.runtime.fs_read(fd_src, buf, write_size, nread)
            fly.runtime.fs_close(fd_src)
        }
    }
    long cpath_dst = 0
    strToCstr(dst, cpath_dst)
    int flags = 577
    int fd_dst = 0
    fly.runtime.fs_open(cpath_dst, flags, 420, fd_dst)
    if fd_dst < 0 { return }
    long nwritten = 0
    fly.runtime.fs_write(fd_dst, buf, write_size, nwritten)
    fly.runtime.fs_close(fd_dst)
}

public fsMove(const string src, const string dst) {
    long csrc = 0
    long cdst = 0
    strToCstr(src, csrc)
    strToCstr(dst, cdst)
    int ret = 0
    fly.runtime.fs_rename(csrc, cdst, ret)
}

public fsRename(const string src, const string dst) {
    long csrc = 0
    long cdst = 0
    strToCstr(src, csrc)
    strToCstr(dst, cdst)
    int ret = 0
    fly.runtime.fs_rename(csrc, cdst, ret)
}

public fsDirCreate(const string path, const int perm) {
    long cpath = 0
    strToCstr(path, cpath)
    int ret = 0
    fly.runtime.fs_mkdir(cpath, perm, ret)
}

public fsDirCreateAll(const string path, const int perm) {
    int plen = 0
    fly.llvm.strSize(path, plen)
    if plen == 0 { return }

    // copy path into a mutable buffer so we can null-terminate at each '/'
    long buf = 0
    fly.runtime.mem_alloc(plen + 2, buf)
    int k = 0
    while k < plen {
        byte bk = 0
        fly.llvm.strByteAt(path, k, bk)
        fly.llvm.strPoke(buf, k, bk)
        k = k + 1
    }
    fly.llvm.strPoke(buf, plen, 0)

    int i = 1   // start at 1 (skip root '/' or first component char)
    while i <= plen {
        byte b = 0
        if i < plen { fly.llvm.ptrByteAt(buf, i, b) }
        bool at_bound = false
        if b == 47 { at_bound = true }
        if i == plen { at_bound = true }
        if at_bound {
            // temporarily null-terminate here
            fly.llvm.strPoke(buf, i, 0)
            int ret = 0
            fly.runtime.fs_mkdir(buf, perm, ret)
            // restore original byte
            fly.llvm.strPoke(buf, i, b)
        }
        i = i + 1
    }
}

public fsDirDelete(const string path) {
    long cpath = 0
    strToCstr(path, cpath)
    int ret = 0
    fly.runtime.fs_rmdir(cpath, ret)
}

public fsDirDeleteAll(const string path) {
    // open the directory
    long cpath = 0
    strToCstr(path, cpath)
    int fd = 0
    fly.runtime.fs_open(cpath, 0, 0, fd)
    if fd < 0 { return }

    // read entries with getdents64
    int bufsize = 4096
    long dbuf = 0
    fly.runtime.mem_alloc(bufsize, dbuf)

    bool done = false
    while done == false {
        int nbytes = 0
        fly.runtime.fs_getdents(fd, dbuf, bufsize, nbytes)
        if nbytes <= 0 {
            done = true
        } else {
            int pos = 0
            while pos < nbytes {
                // d_reclen at bytes 16-17 (little-endian uint16)
                byte rlen_lo = 0
                byte rlen_hi = 0
                fly.llvm.ptrByteAt(dbuf, pos + 16, rlen_lo)
                fly.llvm.ptrByteAt(dbuf, pos + 17, rlen_hi)
                int rlo = rlen_lo
                int rhi = rlen_hi
                int reclen = rlo + rhi * 256
                if reclen <= 0 { done = true }

                // d_type at byte 18: 4=DT_DIR, 8=DT_REG, 10=DT_LNK
                byte dtype = 0
                fly.llvm.ptrByteAt(dbuf, pos + 18, dtype)

                // d_name from byte 19 (null-terminated)
                int name_len = 0
                byte nb = 1
                while nb != 0 {
                    fly.llvm.ptrByteAt(dbuf, pos + 19 + name_len, nb)
                    if nb != 0 { name_len = name_len + 1 }
                }

                // skip "." and ".."
                bool skip = false
                if name_len == 1 {
                    byte n0 = 0
                    fly.llvm.ptrByteAt(dbuf, pos + 19, n0)
                    if n0 == 46 { skip = true }
                }
                if name_len == 2 {
                    byte n0 = 0
                    byte n1 = 0
                    fly.llvm.ptrByteAt(dbuf, pos + 19, n0)
                    fly.llvm.ptrByteAt(dbuf, pos + 20, n1)
                    if n0 == 46 { if n1 == 46 { skip = true } }
                }

                if skip == false {
                    if reclen > 0 {
                        // Build entry_path = path + "/" + name into a fresh buffer
                        // (cannot use strMake with interior pointer dbuf+pos+19 as
                        //  Fly frees the string ptr at function exit)
                        int path_len = 0
                        fly.llvm.strSize(path, path_len)
                        int ep_total = path_len + 1 + name_len
                        long ep_buf = 0
                        fly.runtime.mem_alloc(ep_total + 1, ep_buf)
                        int ki = 0
                        while ki < path_len {
                            byte pb = 0
                            fly.llvm.strByteAt(path, ki, pb)
                            fly.llvm.strPoke(ep_buf, ki, pb)
                            ki = ki + 1
                        }
                        fly.llvm.strPoke(ep_buf, path_len, 47)
                        int ni2 = 0
                        while ni2 < name_len {
                            byte nb2 = 0
                            fly.llvm.ptrByteAt(dbuf, pos + 19 + ni2, nb2)
                            fly.llvm.strPoke(ep_buf, path_len + 1 + ni2, nb2)
                            ni2 = ni2 + 1
                        }
                        fly.llvm.strPoke(ep_buf, ep_total, 0)
                        string entry_path = ""
                        fly.llvm.strMake(ep_buf, ep_total, entry_path)

                        if dtype == 4 {
                            fsDirDeleteAll(entry_path)
                        } else {
                            long centry = 0
                            strToCstr(entry_path, centry)
                            int ret = 0
                            fly.runtime.fs_unlink(centry, ret)
                        }
                    }
                }

                if reclen > 0 { pos = pos + reclen } else { done = true }
            }
        }
    }

    fly.runtime.fs_close(fd)
    int ret2 = 0
    fly.runtime.fs_rmdir(cpath, ret2)
}

public fsDirRead(const string path, fly_dir_entries out) {
    // stub: requires writing composite fly_dir_entry structs to raw memory
    out.items = 0
    out.len = 0
    out.cap = 0
}

public fsSymlinkCreate(const string target, const string link) {
    long ctarget = 0
    long clink = 0
    strToCstr(target, ctarget)
    strToCstr(link, clink)
    int ret = 0
    fly.runtime.fs_symlink(ctarget, clink, ret)
}

public fsSymlinkRead(const string path, string out) {
    long cpath = 0
    strToCstr(path, cpath)
    int cap = 4096
    long buf = 0
    fly.runtime.mem_alloc(cap, buf)
    int nread = 0
    fly.runtime.fs_readlink(cpath, buf, cap, nread)
    if nread <= 0 {
        fly.llvm.strMake(buf, 0, out)
        return
    }
    fly.llvm.strMake(buf, nread, out)
}

public fsTempFile(const string dir, const string pattern, string out_path, fly_file out_file) {
    long base_ns = 0
    fly.runtime.time_mono_ns(base_ns)

    int plen = 0
    fly.llvm.strSize(pattern, plen)

    int counter = 0
    while counter < 10000 {
        long name_buf = 0
        fly.runtime.mem_alloc(plen + 32, name_buf)
        int k = 0
        while k < plen {
            byte bk = 0
            fly.llvm.strByteAt(pattern, k, bk)
            fly.llvm.strPoke(name_buf, k, bk)
            k = k + 1
        }
        int npos = plen
        long unique = base_ns + counter
        int npos2 = 0
        appendDecimal(unique, name_buf, npos, npos2)
        npos = npos2
        string name_str = ""
        fly.llvm.strMake(name_buf, npos, name_str)
        string full_path = ""
        pathJoin(dir, name_str, full_path)
        long cpath = 0
        strToCstr(full_path, cpath)
        // O_WRONLY|O_CREAT|O_EXCL = 1|64|128 = 193, mode 0600 = 384
        int fd = 0
        fly.runtime.fs_open(cpath, 193, 384, fd)
        if fd >= 0 {
            out_path = full_path
            out_file.fd = fd
            out_file.flags = 2
            return
        }
        counter = counter + 1
    }
    out_file.fd = 0 - 1
    out_file.flags = 0
}

public fsTempDir(const string dir, const string pattern, string out_path) {
    long base_ns = 0
    fly.runtime.time_mono_ns(base_ns)

    int plen = 0
    fly.llvm.strSize(pattern, plen)
    string name_str = ""

    int counter = 0
    while counter < 10000 {
        long name_buf = 0
        fly.runtime.mem_alloc(plen + 32, name_buf)
        int k = 0
        while k < plen {
            byte bk = 0
            fly.llvm.strByteAt(pattern, k, bk)
            fly.llvm.strPoke(name_buf, k, bk)
            k = k + 1
        }
        int npos = plen
        long unique = base_ns + counter
        int npos2 = 0
        appendDecimal(unique, name_buf, npos, npos2)
        npos = npos2
        fly.llvm.strMake(name_buf, npos, name_str)
        pathJoin(dir, name_str, out_path)
        long cpath = 0
        strToCstr(out_path, cpath)
        // mode 0700 = 448
        int ret = 0
        fly.runtime.fs_mkdir(cpath, 448, ret)
        if ret >= 0 {
            return
        }
        counter = counter + 1
    }
}

// ── Primitive convenience wrappers ───────────────────────────────────────────

// Write a Fly string to a file (creates/truncates).
public fsWriteStr(const string path, const string content, const int perm) {
    long cpath = 0
    strToCstr(path, cpath)
    long ptr = 0
    int size = 0
    fly.llvm.strGetPtr(content, ptr)
    fly.llvm.strSize(content, size)
    int flags = 577   // O_WRONLY|O_CREAT|O_TRUNC
    int fd = 0
    fly.runtime.fs_open(cpath, flags, perm, fd)
    if fd < 0 { return }
    long nwritten = 0
    fly.runtime.fs_write(fd, ptr, size, nwritten)
    fly.runtime.fs_close(fd)
}

// Read file contents into a Fly string.
public fsReadStr(const string path, string out) {
    ulong fsize = 0
    fsSize(path, fsize)
    if fsize == 0 {
        long empty = 0
        fly.runtime.mem_alloc(1, empty)
        fly.llvm.strMake(empty, 0, out)
        return
    }
    ulong cap = fsize
    long buf = 0
    fly.runtime.mem_alloc(cap, buf)
    long cpath = 0
    strToCstr(path, cpath)
    int fd = 0
    fly.runtime.fs_open(cpath, 0, 0, fd)
    if fd < 0 {
        fly.llvm.strMake(buf, 0, out)
        return
    }
    long nread = 0
    fly.runtime.fs_read(fd, buf, fsize, nread)
    fly.runtime.fs_close(fd)
    if nread > 0 {
        int nread_int = 0
        fly.llvm.longToInt(nread, nread_int)
        fly.llvm.strMake(buf, nread_int, out)
    } else {
        fly.llvm.strMake(buf, 0, out)
    }
}

// Append a Fly string to a file.
public fsAppendStr(const string path, const string content, const int perm) {
    long cpath = 0
    strToCstr(path, cpath)
    long ptr = 0
    int size = 0
    fly.llvm.strGetPtr(content, ptr)
    fly.llvm.strSize(content, size)
    int flags = 1089  // O_WRONLY|O_CREAT|O_APPEND
    int fd = 0
    fly.runtime.fs_open(cpath, flags, perm, fd)
    if fd < 0 { return }
    long nwritten = 0
    fly.runtime.fs_write(fd, ptr, size, nwritten)
    fly.runtime.fs_close(fd)
}

// Return current Unix timestamp (seconds since epoch).
public timeNowSec(long out) {
    long total_ns = 0
    fly.runtime.time_now_ns(total_ns)
    long ns_per_sec = 1000000000
    out = total_ns / ns_per_sec
}

// Format a duration (given as nanoseconds) to a human-readable string.
public durationFormatNsec(const long nsec, string out) {
    long ns = nsec
    if ns < 0 { ns = 0 - ns }
    if ns == 0 {
        long b0 = 0
        fly.runtime.mem_alloc(4, b0)
        fly.llvm.strPoke(b0, 0, 48)
        fly.llvm.strPoke(b0, 1, 115)
        fly.llvm.strMake(b0, 2, out)
        return
    }

    long ns_per_hr  = 3600000000000
    long ns_per_min = 60000000000
    long ns_per_sec = 1000000000
    long ns_per_ms  = 1000000
    long ns_per_us  = 1000

    long hours = ns / ns_per_hr
    long rem   = ns - hours * ns_per_hr
    long mins  = rem / ns_per_min
    rem        = rem - mins * ns_per_min
    long secs  = rem / ns_per_sec
    rem        = rem - secs * ns_per_sec
    long ms    = rem / ns_per_ms
    rem        = rem - ms * ns_per_ms
    long us    = rem / ns_per_us
    long nanos = rem - us * ns_per_us

    long buf = 0
    fly.runtime.mem_alloc(64, buf)
    int pos = 0

    bool has_large = false
    if hours > 0 { has_large = true }
    if mins > 0  { has_large = true }
    if secs > 0  { has_large = true }

    int p2 = 0
    if has_large {
        if hours > 0 {
            appendDecimal(hours, buf, pos, p2)
            pos = p2
            fly.llvm.strPoke(buf, pos, 104)
            pos = pos + 1
        }
        bool has_hm = false
        if hours > 0 { has_hm = true }
        if mins > 0  { has_hm = true }
        if has_hm {
            if hours > 0 {
                if mins < 10 {
                    fly.llvm.strPoke(buf, pos, 48)
                    pos = pos + 1
                }
            }
            appendDecimal(mins, buf, pos, p2)
            pos = p2
            fly.llvm.strPoke(buf, pos, 109)
            pos = pos + 1
        }
        if has_hm {
            if secs < 10 {
                fly.llvm.strPoke(buf, pos, 48)
                pos = pos + 1
            }
        }
        appendDecimal(secs, buf, pos, p2)
        pos = p2
        fly.llvm.strPoke(buf, pos, 115)
        pos = pos + 1
    } elsif ms > 0 {
        appendDecimal(ms, buf, pos, p2)
        pos = p2
        fly.llvm.strPoke(buf, pos, 109)
        pos = pos + 1
        fly.llvm.strPoke(buf, pos, 115)
        pos = pos + 1
    } elsif us > 0 {
        appendDecimal(us, buf, pos, p2)
        pos = p2
        fly.llvm.strPoke(buf, pos, 117)
        pos = pos + 1
        fly.llvm.strPoke(buf, pos, 115)
        pos = pos + 1
    } else {
        appendDecimal(nanos, buf, pos, p2)
        pos = p2
        fly.llvm.strPoke(buf, pos, 110)
        pos = pos + 1
        fly.llvm.strPoke(buf, pos, 115)
        pos = pos + 1
    }

    fly.llvm.strMake(buf, pos, out)
}

// Count environment variables.
public envAllCount(int out) {
    fly.runtime.env_all_count(out)
}

// Count path components (counts non-empty segments separated by '/').
public pathCompCount(const string path, int out) {
    int plen = 0
    fly.llvm.strSize(path, plen)
    int count = 0
    bool in_comp = false
    int start = 0
    if plen > 0 {
        byte fb = 0
        fly.llvm.strByteAt(path, 0, fb)
        if fb == 47 { start = 1 }
    }
    int i = start
    while i < plen {
        byte b = 0
        fly.llvm.strByteAt(path, i, b)
        if b == 47 {
            if in_comp { count = count + 1 }
            in_comp = false
        } else {
            in_comp = true
        }
        i = i + 1
    }
    if in_comp { count = count + 1 }
    out = count
}

// stat: returns true if path is a regular file.
// S_IFREG = 0x8000 → mode & 0xF000 == 0x8000 → (mode >> 12) & 0xF == 8
public fsIsFile(const string path, bool out) {
    long cpath = 0
    strToCstr(path, cpath)
    int fmode = 0
    fly.runtime.fs_mode(cpath, fmode)
    if fmode < 0 {
        out = false
        return
    }
    int ftype = fmode / 4096
    int ftype16 = ftype - (ftype / 16) * 16
    if ftype16 == 8 { out = true } else { out = false }
}

// stat: returns true if path is a directory.
// S_IFDIR = 0x4000 → (mode >> 12) & 0xF == 4
public fsIsDir(const string path, bool out) {
    long cpath = 0
    strToCstr(path, cpath)
    int fmode = 0
    fly.runtime.fs_mode(cpath, fmode)
    if fmode < 0 {
        out = false
        return
    }
    int ftype = fmode / 4096
    int ftype16 = ftype - (ftype / 16) * 16
    if ftype16 == 4 { out = true } else { out = false }
}

// ── IO ───────────────────────────────────────────────────────────────────────

public ioRead(Reader r, fly_buf buf, const ulong n, long out_read) {
    r.read(buf, n, out_read)
}

public ioReadAll(Reader r, fly_buf out) {
    int cap = 4096
    long buf = 0
    fly.runtime.mem_alloc(cap, buf)
    int total = 0
    bool done = false
    while done == false {
        int avail = cap - total
        long tmp = 0
        fly.runtime.mem_alloc(avail, tmp)
        fly_buf chunk = new fly_buf()
        chunk.ptr = tmp
        chunk.size = 0
        ulong avail_u = avail
        chunk.cap = avail_u
        long nread = 0
        r.read(chunk, avail_u, nread)
        if nread == 0 {
            done = true
        } else {
            int nread_int = 0
            fly.llvm.longToInt(nread, nread_int)
            int i = 0
            while i < nread_int {
                byte b = 0
                fly.llvm.ptrByteAt(tmp, i, b)
                fly.llvm.strPoke(buf, total + i, b)
                i = i + 1
            }
            total = total + nread_int
            if total >= cap {
                int newcap = cap * 2
                long newbuf = 0
                fly.runtime.mem_alloc(newcap, newbuf)
                int j = 0
                while j < total {
                    byte bb = 0
                    fly.llvm.ptrByteAt(buf, j, bb)
                    fly.llvm.strPoke(newbuf, j, bb)
                    j = j + 1
                }
                buf = newbuf
                cap = newcap
            }
        }
    }
    out.ptr = buf
    out.size = total
    out.cap = cap
}

public ioReadLine(Reader r, string out) {
    int cap = 256
    long buf = 0
    fly.runtime.mem_alloc(cap, buf)
    int pos = 0
    bool done = false
    while done == false {
        long tmp = 0
        fly.runtime.mem_alloc(1, tmp)
        fly_buf chunk = new fly_buf()
        chunk.ptr = tmp
        chunk.size = 0
        chunk.cap = 1
        long nread = 0
        r.read(chunk, 1, nread)
        if nread == 0 {
            done = true
        } else {
            byte b = 0
            fly.llvm.ptrByteAt(tmp, 0, b)
            if b == 10 {
                done = true
            } else {
                if pos >= cap {
                    int newcap = cap * 2
                    long newbuf = 0
                    fly.runtime.mem_alloc(newcap, newbuf)
                    int j = 0
                    while j < pos {
                        byte bb = 0
                        fly.llvm.ptrByteAt(buf, j, bb)
                        fly.llvm.strPoke(newbuf, j, bb)
                        j = j + 1
                    }
                    buf = newbuf
                    cap = newcap
                }
                fly.llvm.strPoke(buf, pos, b)
                pos = pos + 1
            }
        }
    }
    fly.llvm.strMake(buf, pos, out)
}

public ioReadLines(Reader r, fly_string_array out) {
    int arr_cap = 16
    long arr = 0
    fly.runtime.mem_alloc(arr_cap * 16, arr)
    int count = 0
    bool at_eof = false
    while at_eof == false {
        int line_cap = 256
        long line_buf = 0
        fly.runtime.mem_alloc(line_cap, line_buf)
        int pos = 0
        bool line_done = false
        while line_done == false {
            long tmp = 0
            fly.runtime.mem_alloc(1, tmp)
            fly_buf chunk = new fly_buf()
            chunk.ptr = tmp
            chunk.size = 0
            chunk.cap = 1
            long nread = 0
            r.read(chunk, 1, nread)
            if nread == 0 {
                line_done = true
                at_eof = true
            } else {
                byte b = 0
                fly.llvm.ptrByteAt(tmp, 0, b)
                if b == 10 {
                    line_done = true
                } else {
                    if pos >= line_cap {
                        int newcap = line_cap * 2
                        long newbuf = 0
                        fly.runtime.mem_alloc(newcap, newbuf)
                        int j = 0
                        while j < pos {
                            byte bb = 0
                            fly.llvm.ptrByteAt(line_buf, j, bb)
                            fly.llvm.strPoke(newbuf, j, bb)
                            j = j + 1
                        }
                        line_buf = newbuf
                        line_cap = newcap
                    }
                    fly.llvm.strPoke(line_buf, pos, b)
                    pos = pos + 1
                }
            }
        }
        bool add_line = false
        if at_eof == false { add_line = true }
        if pos > 0 { add_line = true }
        if add_line {
            if count >= arr_cap {
                int newcap = arr_cap * 2
                long newarr = 0
                fly.runtime.mem_alloc(newcap * 16, newarr)
                int bytes = arr_cap * 16
                int j = 0
                while j < bytes {
                    byte bb = 0
                    fly.llvm.ptrByteAt(arr, j, bb)
                    fly.llvm.strPoke(newarr, j, bb)
                    j = j + 1
                }
                arr = newarr
                arr_cap = newcap
            }
            fly.runtime.str_slot_set(arr, count, line_buf, pos)
            count = count + 1
        }
    }
    out.items = arr
    out.count = count
}

