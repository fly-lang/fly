// copy copies all bytes from Reader src to Writer dst using an 8 KiB chunk buffer.
// Writes the total byte count into out_copied.
public long copy(Reader src, Writer dst) {
    int chunk_sz = 8192
    long tmp = 0
    fly.runtime.mem_alloc(chunk_sz, tmp)
    long total = 0
    bool done = false
    while done == false {
        Buf chunk = new Buf()
        chunk.ptr = tmp
        chunk.size = 0
        ulong chunk_sz_u = chunk_sz
        chunk.cap = chunk_sz_u
        long nread = 0
        nread = src.read(chunk, chunk_sz_u)
        if nread == 0 {
            done = true
        } else {
            chunk.size = nread
            long nwritten = 0
            nwritten = dst.write(chunk, chunk_sz_u)
            if nwritten < 0 { done = true }
            total = total + nread
        }
    }
    out = total
}

// copyN copies at most n bytes from src to dst using an 8 KiB chunk buffer.
// Stops at n bytes or EOF, whichever comes first.  Writes actual count to out_copied.
public long copyN(Reader src, Writer dst, const ulong n) {
    int chunk_sz = 8192
    long tmp = 0
    fly.runtime.mem_alloc(chunk_sz, tmp)
    long total = 0
    ulong remaining = n
    bool done = false
    while done == false {
        if remaining == 0 {
            done = true
        } else {
            ulong chunk_sz_u = chunk_sz
            ulong to_read = chunk_sz_u
            if remaining < to_read { to_read = remaining }
            Buf chunk = new Buf()
            chunk.ptr = tmp
            chunk.size = 0
            chunk.cap = to_read
            long nread = 0
            nread = src.read(chunk, to_read)
            if nread == 0 {
                done = true
            } else {
                chunk.size = nread
                long nwritten = 0
                nwritten = dst.write(chunk, to_read)
                if nwritten < 0 { done = true }
                total = total + nread
                ulong nread_u = nread
                remaining = remaining - nread_u
            }
        }
    }
    out = total
}

// pipe copies all bytes from pipe_r to pipe_w until EOF.
// Returns the total number of bytes copied (same as copy).
public long pipe(Reader pipe_r, Writer pipe_w) {
    out = copy(pipe_r, pipe_w)
}

// printErr writes s to stderr (fd=2) without a trailing newline.
public void printErr(const string s) {
    Writer w = fileWriter(2)
    writeString(w, s)
}

// printErrLn writes s to stderr (fd=2) followed by a newline.
public void printErrLn(const string s) {
    Writer w = fileWriter(2)
    writeString(w, s)
    writeString(w, "\n")
}

// print writes s to stdout (fd=1) without a trailing newline.
public void print(const string s) {
    Writer w = fileWriter(1)
    writeString(w, s)
}

// printLn writes s to stdout (fd=1) followed by a newline.
public void printLn(const string s) {
    Writer w = fileWriter(1)
    writeString(w, s)
    writeString(w, "\n")
}
