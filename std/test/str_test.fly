import fly.str
import fly.assert

main() {
    int n = 0
    bool b = false
    string s = ""

    // ── len ───────────────────────────────────────────────────────────────────
    str.len("hello", n)
    assert.assertEqI(n, 5, 1)
    str.len("", n)
    assert.assertEqI(n, 0, 2)

    // ── isEmpty ───────────────────────────────────────────────────────────────
    str.isEmpty("", b)
    if b == false { assert.errExit(10) }
    str.isEmpty("x", b)
    if b { assert.errExit(11) }

    // ── equals ────────────────────────────────────────────────────────────────
    str.equals("abc", "abc", b)
    if b == false { assert.errExit(20) }
    str.equals("abc", "ABC", b)
    if b { assert.errExit(21) }
    str.equals("", "", b)
    if b == false { assert.errExit(22) }

    // ── equalsIgnoreCase ──────────────────────────────────────────────────────
    str.equalsIgnoreCase("Hello", "HELLO", b)
    if b == false { assert.errExit(30) }
    str.equalsIgnoreCase("abc", "xyz", b)
    if b { assert.errExit(31) }

    // ── startsWith ────────────────────────────────────────────────────────────
    str.startsWith("hello world", "hello", b)
    if b == false { assert.errExit(40) }
    str.startsWith("hello world", "world", b)
    if b { assert.errExit(41) }
    str.startsWith("hello", "", b)
    if b == false { assert.errExit(42) }

    // ── endsWith ──────────────────────────────────────────────────────────────
    str.endsWith("hello world", "world", b)
    if b == false { assert.errExit(50) }
    str.endsWith("hello world", "hello", b)
    if b { assert.errExit(51) }

    // ── indexOf ───────────────────────────────────────────────────────────────
    str.indexOf("hello world", "world", n)
    assert.assertEqI(n, 6, 60)
    str.indexOf("hello world", "xyz", n)
    int neg1 = 0 - 1
    assert.assertEqI(n, neg1, 61)
    str.indexOf("abab", "ab", n)
    assert.assertEqI(n, 0, 62)

    // ── lastIndexOf ───────────────────────────────────────────────────────────
    str.lastIndexOf("abcabc", "bc", n)
    assert.assertEqI(n, 4, 70)
    str.lastIndexOf("abcabc", "ab", n)
    assert.assertEqI(n, 3, 71)

    // ── contains ──────────────────────────────────────────────────────────────
    str.contains("hello world", "world", b)
    if b == false { assert.errExit(80) }
    str.contains("hello world", "xyz", b)
    if b { assert.errExit(81) }

    // ── count ─────────────────────────────────────────────────────────────────
    str.count("abcabcabc", "abc", n)
    assert.assertEqI(n, 3, 90)
    str.count("aaa", "a", n)
    assert.assertEqI(n, 3, 91)
    str.count("abc", "xyz", n)
    assert.assertEqI(n, 0, 92)

    // ── toUpper ───────────────────────────────────────────────────────────────
    str.toUpper("hello", s)
    assert.assertStr(s, "HELLO", 100)
    str.toUpper("Hello World", s)
    assert.assertStr(s, "HELLO WORLD", 101)

    // ── toLower ───────────────────────────────────────────────────────────────
    str.toLower("WORLD", s)
    assert.assertStr(s, "world", 110)
    str.toLower("Hello World", s)
    assert.assertStr(s, "hello world", 111)

    // ── trim ──────────────────────────────────────────────────────────────────
    str.trim("  hello  ", s)
    assert.assertStr(s, "hello", 120)
    str.trim("hello", s)
    assert.assertStr(s, "hello", 121)
    str.trim("", s)
    assert.assertStr(s, "", 122)

    // ── trimLeft ──────────────────────────────────────────────────────────────
    str.trimLeft("  hello  ", s)
    assert.assertStr(s, "hello  ", 130)

    // ── trimRight ─────────────────────────────────────────────────────────────
    str.trimRight("  hello  ", s)
    assert.assertStr(s, "  hello", 140)

    // ── substring ─────────────────────────────────────────────────────────────
    str.substring("hello world", 6, 11, s)
    assert.assertStr(s, "world", 150)
    str.substring("hello world", 0, 5, s)
    assert.assertStr(s, "hello", 151)
    str.substring("abc", 1, 2, s)
    assert.assertStr(s, "b", 152)

    // ── concat ────────────────────────────────────────────────────────────────
    str.concat("hello ", "world", s)
    assert.assertStr(s, "hello world", 160)
    str.concat("", "abc", s)
    assert.assertStr(s, "abc", 161)
    str.concat("abc", "", s)
    assert.assertStr(s, "abc", 162)

    // ── repeat ────────────────────────────────────────────────────────────────
    str.repeat("ab", 3, s)
    assert.assertStr(s, "ababab", 170)
    str.repeat("x", 1, s)
    assert.assertStr(s, "x", 171)
    str.repeat("abc", 0, s)
    assert.assertStr(s, "", 172)

    // ── replace ───────────────────────────────────────────────────────────────
    str.replace("aabbaa", "aa", "X", s)
    assert.assertStr(s, "XbbX", 180)
    str.replace("hello world", "world", "fly", s)
    assert.assertStr(s, "hello fly", 181)
    str.replace("abc", "xyz", "Z", s)
    assert.assertStr(s, "abc", 182)

    // ── convert ───────────────────────────────────────────────────────────────
    str.convert(0, s)
    assert.assertStr(s, "0", 190)
    str.convert(42, s)
    assert.assertStr(s, "42", 191)
    int neg_one = 0 - 1
    str.convert(neg_one, s)
    assert.assertStr(s, "-1", 192)
    str.convert(2147483647, s)
    assert.assertStr(s, "2147483647", 193)
}
