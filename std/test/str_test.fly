import fly.str
import fly.assert

void main() {
    int n = 0
    bool b = false
    string s = ""

    // ── len ───────────────────────────────────────────────────────────────────
    n = str.len("hello")
    assert.assertEqI(n, 5, 1)
    n = str.len("")
    assert.assertEqI(n, 0, 2)

    // ── isEmpty ───────────────────────────────────────────────────────────────
    b = str.isEmpty("")
    if b == false { assert.errExit(10) }
    b = str.isEmpty("x")
    if b { assert.errExit(11) }

    // ── equals ────────────────────────────────────────────────────────────────
    b = str.equals("abc", "abc")
    if b == false { assert.errExit(20) }
    b = str.equals("abc", "ABC")
    if b { assert.errExit(21) }
    b = str.equals("", "")
    if b == false { assert.errExit(22) }

    // ── equalsIgnoreCase ──────────────────────────────────────────────────────
    b = str.equalsIgnoreCase("Hello", "HELLO")
    if b == false { assert.errExit(30) }
    b = str.equalsIgnoreCase("abc", "xyz")
    if b { assert.errExit(31) }

    // ── startsWith ────────────────────────────────────────────────────────────
    b = str.startsWith("hello world", "hello")
    if b == false { assert.errExit(40) }
    b = str.startsWith("hello world", "world")
    if b { assert.errExit(41) }
    b = str.startsWith("hello", "")
    if b == false { assert.errExit(42) }

    // ── endsWith ──────────────────────────────────────────────────────────────
    b = str.endsWith("hello world", "world")
    if b == false { assert.errExit(50) }
    b = str.endsWith("hello world", "hello")
    if b { assert.errExit(51) }

    // ── indexOf ───────────────────────────────────────────────────────────────
    n = str.indexOf("hello world", "world")
    assert.assertEqI(n, 6, 60)
    n = str.indexOf("hello world", "xyz")
    int neg1 = 0 - 1
    assert.assertEqI(n, neg1, 61)
    n = str.indexOf("abab", "ab")
    assert.assertEqI(n, 0, 62)

    // ── lastIndexOf ───────────────────────────────────────────────────────────
    n = str.lastIndexOf("abcabc", "bc")
    assert.assertEqI(n, 4, 70)
    n = str.lastIndexOf("abcabc", "ab")
    assert.assertEqI(n, 3, 71)

    // ── contains ──────────────────────────────────────────────────────────────
    b = str.contains("hello world", "world")
    if b == false { assert.errExit(80) }
    b = str.contains("hello world", "xyz")
    if b { assert.errExit(81) }

    // ── count ─────────────────────────────────────────────────────────────────
    n = str.count("abcabcabc", "abc")
    assert.assertEqI(n, 3, 90)
    n = str.count("aaa", "a")
    assert.assertEqI(n, 3, 91)
    n = str.count("abc", "xyz")
    assert.assertEqI(n, 0, 92)

    // ── toUpper ───────────────────────────────────────────────────────────────
    s = str.toUpper("hello")
    assert.assertStr(s, "HELLO", 100)
    s = str.toUpper("Hello World")
    assert.assertStr(s, "HELLO WORLD", 101)

    // ── toLower ───────────────────────────────────────────────────────────────
    s = str.toLower("WORLD")
    assert.assertStr(s, "world", 110)
    s = str.toLower("Hello World")
    assert.assertStr(s, "hello world", 111)

    // ── trim ──────────────────────────────────────────────────────────────────
    s = str.trim("  hello  ")
    assert.assertStr(s, "hello", 120)
    s = str.trim("hello")
    assert.assertStr(s, "hello", 121)
    s = str.trim("")
    assert.assertStr(s, "", 122)

    // ── trimLeft ──────────────────────────────────────────────────────────────
    s = str.trimLeft("  hello  ")
    assert.assertStr(s, "hello  ", 130)

    // ── trimRight ─────────────────────────────────────────────────────────────
    s = str.trimRight("  hello  ")
    assert.assertStr(s, "  hello", 140)

    // ── substring ─────────────────────────────────────────────────────────────
    s = str.substring("hello world", 6, 11)
    assert.assertStr(s, "world", 150)
    s = str.substring("hello world", 0, 5)
    assert.assertStr(s, "hello", 151)
    s = str.substring("abc", 1, 2)
    assert.assertStr(s, "b", 152)

    // ── concat ────────────────────────────────────────────────────────────────
    s = str.concat("hello ", "world")
    assert.assertStr(s, "hello world", 160)
    s = str.concat("", "abc")
    assert.assertStr(s, "abc", 161)
    s = str.concat("abc", "")
    assert.assertStr(s, "abc", 162)

    // ── repeat ────────────────────────────────────────────────────────────────
    s = str.repeat("ab", 3)
    assert.assertStr(s, "ababab", 170)
    s = str.repeat("x", 1)
    assert.assertStr(s, "x", 171)
    s = str.repeat("abc", 0)
    assert.assertStr(s, "", 172)

    // ── replace ───────────────────────────────────────────────────────────────
    s = str.replace("aabbaa", "aa", "X")
    assert.assertStr(s, "XbbX", 180)
    s = str.replace("hello world", "world", "fly")
    assert.assertStr(s, "hello fly", 181)
    s = str.replace("abc", "xyz", "Z")
    assert.assertStr(s, "abc", 182)

    // ── convert ───────────────────────────────────────────────────────────────
    s = str.convert(0)
    assert.assertStr(s, "0", 190)
    s = str.convert(42)
    assert.assertStr(s, "42", 191)
    int neg_one = 0 - 1
    s = str.convert(neg_one)
    assert.assertStr(s, "-1", 192)
    s = str.convert(2147483647)
    assert.assertStr(s, "2147483647", 193)
}
