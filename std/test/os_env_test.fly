import fly.os.env
import fly.assert

main() {
    string s = ""
    int n = 0

    fly.os.env.osname(s)
    fly.assert.assertNotEmpty(s, 1)

    fly.os.env.argsCount(n)
    fly.assert.assertGtI(n, 0, 2)

    fly.os.env.hostname(s)
    fly.assert.assertNotEmpty(s, 3)

    fly.os.env.allCount(n)
    fly.assert.assertGtI(n, 0, 4)

    fly.os.env.set("FLY_ENV_TEST_VAR", "hello_env")
    fly.os.env.get("FLY_ENV_TEST_VAR", s)
    fly.assert.assertStr(s, "hello_env", 10)

    fly.os.env.delete("FLY_ENV_TEST_VAR")
    fly.os.env.get("FLY_ENV_TEST_VAR", s)
    fly.assert.assertStr(s, "", 11)

    fly.os.env.set("FLY_ENV_EXP", "world")
    fly.os.env.expand("hello $FLY_ENV_EXP", s)
    fly.assert.assertStr(s, "hello world", 12)
    fly.os.env.expand("${FLY_ENV_EXP}!", s)
    fly.assert.assertStr(s, "world!", 13)
    fly.os.env.delete("FLY_ENV_EXP")

    fly.os.env.cwdGet(s)
    fly.assert.assertNotEmpty(s, 14)
}
