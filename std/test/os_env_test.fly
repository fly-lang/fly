import fly.os.env
import fly.assert

main() {
    string s = ""
    int n = 0

    env.osname(s)
    assert.assertNotEmpty(s, 1)

    env.argsCount(n)
    assert.assertGtI(n, 0, 2)

    env.hostname(s)
    assert.assertNotEmpty(s, 3)

    env.allCount(n)
    assert.assertGtI(n, 0, 4)

    env.set("FLY_ENV_TEST_VAR", "hello_env")
    env.get("FLY_ENV_TEST_VAR", s)
    assert.assertStr(s, "hello_env", 10)

    env.delete("FLY_ENV_TEST_VAR")
    env.get("FLY_ENV_TEST_VAR", s)
    assert.assertStr(s, "", 11)

    env.set("FLY_ENV_EXP", "world")
    env.expand("hello $FLY_ENV_EXP", s)
    assert.assertStr(s, "hello world", 12)
    env.expand("${FLY_ENV_EXP}!", s)
    assert.assertStr(s, "world!", 13)
    env.delete("FLY_ENV_EXP")

    env.cwdGet(s)
    assert.assertNotEmpty(s, 14)
}
