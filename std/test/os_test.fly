import fly.os
import fly.assert

main() {
    string s = ""
    bool b = false
    int n = 0

    // ── envOsname ────────────────────────────────────────────────────────────
    fly.os.envOsname(s)
    fly.assert.assertNotEmpty(s, 1)

    // ── envArgsCount ─────────────────────────────────────────────────────────
    fly.os.envArgsCount(n)
    fly.assert.assertGtI(n, 0, 2)

    // ── envHostname ──────────────────────────────────────────────────────────
    fly.os.envHostname(s)
    fly.assert.assertNotEmpty(s, 3)

    // ── envAllCount ──────────────────────────────────────────────────────────
    fly.os.envAllCount(n)
    fly.assert.assertGtI(n, 0, 4)

    // ── envSet + envGet ──────────────────────────────────────────────────────
    fly.os.envSet("FLY_OS_TEST_VAR", "hello_fly")
    fly.os.envGet("FLY_OS_TEST_VAR", s)
    fly.assert.assertStr(s, "hello_fly", 10)

    // ── envDelete ────────────────────────────────────────────────────────────
    fly.os.envDelete("FLY_OS_TEST_VAR")
    fly.os.envGet("FLY_OS_TEST_VAR", s)
    fly.assert.assertStr(s, "", 11)

    // ── envExpand ────────────────────────────────────────────────────────────
    fly.os.envSet("FLY_EXP_VAR", "world")
    fly.os.envExpand("hello $FLY_EXP_VAR", s)
    fly.assert.assertStr(s, "hello world", 12)
    fly.os.envExpand("${FLY_EXP_VAR}!", s)
    fly.assert.assertStr(s, "world!", 13)
    fly.os.envDelete("FLY_EXP_VAR")

    // ── envCwdGet ────────────────────────────────────────────────────────────
    fly.os.envCwdGet(s)
    fly.assert.assertNotEmpty(s, 14)

    // ── pathJoin ─────────────────────────────────────────────────────────────
    fly.os.pathJoin("/foo", "bar", s)
    fly.assert.assertStr(s, "/foo/bar", 20)
    fly.os.pathJoin("/foo/", "bar", s)
    fly.assert.assertStr(s, "/foo/bar", 21)
    fly.os.pathJoin("/foo", "/bar", s)
    fly.assert.assertStr(s, "/foo/bar", 22)
    fly.os.pathJoin("", "bar", s)
    fly.assert.assertStr(s, "bar", 23)

    // ── pathNormalize ────────────────────────────────────────────────────────
    fly.os.pathNormalize("/a//b/../c", s)
    fly.assert.assertStr(s, "/a/c", 30)
    fly.os.pathNormalize("/a/./b", s)
    fly.assert.assertStr(s, "/a/b", 31)
    fly.os.pathNormalize("a/b/c", s)
    fly.assert.assertStr(s, "a/b/c", 32)
    fly.os.pathNormalize("/", s)
    fly.assert.assertStr(s, "/", 33)

    // ── pathAbsolute ─────────────────────────────────────────────────────────
    fly.os.pathAbsolute(".", s)
    fly.assert.assertNotEmpty(s, 34)
    fly.os.pathAbsolute("/already/abs", s)
    fly.assert.assertStr(s, "/already/abs", 35)

    // ── pathMatch ────────────────────────────────────────────────────────────
    fly.os.pathMatch("*.fly", "test.fly", b)
    fly.assert.assertTrue(b, 40)
    fly.os.pathMatch("*.fly", "test.go", b)
    fly.assert.assertFalse(b, 41)
    fly.os.pathMatch("foo*", "foobar", b)
    fly.assert.assertTrue(b, 42)
    fly.os.pathMatch("fo?", "foo", b)
    fly.assert.assertTrue(b, 43)
    fly.os.pathMatch("fo?", "fo", b)
    fly.assert.assertFalse(b, 44)
    fly.os.pathMatch("*", "anything", b)
    fly.assert.assertTrue(b, 45)
    fly.os.pathMatch("", "", b)
    fly.assert.assertTrue(b, 46)

    // ── pathExt ──────────────────────────────────────────────────────────────
    fly.os.pathExt("foo.fly", s)
    fly.assert.assertStr(s, ".fly", 50)
    fly.os.pathExt("foo", s)
    fly.assert.assertStr(s, "", 51)

    // ── pathBasename / pathDirname ────────────────────────────────────────────
    fly.os.pathBasename("/foo/bar/baz.fly", s)
    fly.assert.assertStr(s, "baz.fly", 55)
    fly.os.pathDirname("/foo/bar/baz.fly", s)
    fly.assert.assertStr(s, "/foo/bar", 56)
    fly.os.pathDirname("baz.fly", s)
    fly.assert.assertStr(s, ".", 57)

    // ── pathCompCount ────────────────────────────────────────────────────────
    fly.os.pathCompCount("/foo/bar/baz", n)
    fly.assert.assertEqI(n, 3, 60)
    fly.os.pathCompCount("a/b", n)
    fly.assert.assertEqI(n, 2, 61)

    // ── pathRel ───────────────────────────────────────────────────────────────
    fly.os.pathRel("/a/b", "/a/b/c", s)
    fly.assert.assertStr(s, "c", 65)
    fly.os.pathRel("/a/b", "/a/d", s)
    fly.assert.assertStr(s, "../d", 66)

    // ── pathIsSym (on known non-symlink) ─────────────────────────────────────
    fly.os.pathIsSym("/tmp", b)
    // /tmp may or may not be a symlink; just verify no crash — don't assert value

    // ── filesystem setup ─────────────────────────────────────────────────────
    string test_dir = "/tmp/fly_os_test_dir"
    fly.os.fsDirCreateAll(test_dir, 493)   // 0755

    // ── fsExists ─────────────────────────────────────────────────────────────
    fly.os.fsExists(test_dir, b)
    fly.assert.assertTrue(b, 70)
    fly.os.fsExists("/tmp/fly_os_nonexistent_xyzabc", b)
    fly.assert.assertFalse(b, 71)

    // ── fsIsDir ───────────────────────────────────────────────────────────────
    fly.os.fsIsDir(test_dir, b)
    fly.assert.assertTrue(b, 72)
    fly.os.fsIsDir("/tmp/fly_os_nonexistent_xyzabc", b)
    fly.assert.assertFalse(b, 73)

    // ── fsWriteStr + fsReadStr ────────────────────────────────────────────────
    string test_file = "/tmp/fly_os_test_dir/test.txt"
    fly.os.fsWriteStr(test_file, "hello fly!", 420)   // 0644

    fly.os.fsExists(test_file, b)
    fly.assert.assertTrue(b, 80)

    fly.os.fsIsFile(test_file, b)
    fly.assert.assertTrue(b, 81)

    fly.os.fsIsDir(test_file, b)
    fly.assert.assertFalse(b, 82)

    fly.os.fsReadStr(test_file, s)
    fly.assert.assertStr(s, "hello fly!", 83)

    // ── fsSize ────────────────────────────────────────────────────────────────
    ulong fsz = 0
    fly.os.fsSize(test_file, fsz)
    if fsz != 10 { fly.assert.errExit(84) }

    // ── fsCopy ────────────────────────────────────────────────────────────────
    string test_copy = "/tmp/fly_os_test_dir/copy.txt"
    fly.os.fsCopy(test_file, test_copy)
    fly.os.fsExists(test_copy, b)
    fly.assert.assertTrue(b, 85)
    ulong copy_sz = 0
    fly.os.fsSize(test_copy, copy_sz)
    if copy_sz != 10 { fly.assert.errExit(86) }

    // ── fsAppendStr ───────────────────────────────────────────────────────────
    fly.os.fsAppendStr(test_file, "++!", 420)
    ulong appended_sz = 0
    fly.os.fsSize(test_file, appended_sz)
    if appended_sz != 13 { fly.assert.errExit(87) }

    // ── fsTruncate ────────────────────────────────────────────────────────────
    fly.os.fsTruncate(test_file, 5)
    ulong trunc_sz = 0
    fly.os.fsSize(test_file, trunc_sz)
    if trunc_sz != 5 { fly.assert.errExit(88) }

    // ── fsChmod ───────────────────────────────────────────────────────────────
    fly.os.fsChmod(test_file, 384)   // 0600 — no crash expected

    // ── fsMove ────────────────────────────────────────────────────────────────
    string test_moved = "/tmp/fly_os_test_dir/moved.txt"
    fly.os.fsMove(test_copy, test_moved)
    fly.os.fsExists(test_moved, b)
    fly.assert.assertTrue(b, 89)
    fly.os.fsExists(test_copy, b)
    fly.assert.assertFalse(b, 90)

    // ── fsSymlinkCreate + fsSymlinkRead + pathIsSym ───────────────────────────
    string sym_path = "/tmp/fly_os_test_dir/sym.txt"
    fly.os.fsSymlinkCreate(test_file, sym_path)
    fly.os.fsExists(sym_path, b)
    fly.assert.assertTrue(b, 91)
    fly.os.pathIsSym(sym_path, b)
    fly.assert.assertTrue(b, 92)
    fly.os.fsSymlinkRead(sym_path, s)
    fly.assert.assertStr(s, test_file, 93)

    // ── fsTempDir ─────────────────────────────────────────────────────────────
    string tmp_dir_path = ""
    fly.os.fsTempDir("/tmp", "fly_tmpd_", tmp_dir_path)
    fly.assert.assertNotEmpty(tmp_dir_path, 95)
    fly.os.fsIsDir(tmp_dir_path, b)
    fly.assert.assertTrue(b, 96)
    fly.os.fsDirDelete(tmp_dir_path)

    // ── timeNowSec ────────────────────────────────────────────────────────────
    long ts = 0
    fly.os.timeNowSec(ts)
    if ts <= 0 { fly.assert.errExit(100) }

    // ── durationFormatNsec ────────────────────────────────────────────────────
    fly.os.durationFormatNsec(5405000000000, s)   // 1h30m5s
    fly.assert.assertStr(s, "1h30m05s", 110)

    fly.os.durationFormatNsec(500000000, s)   // 500ms
    fly.assert.assertStr(s, "500ms", 111)

    fly.os.durationFormatNsec(200000, s)   // 200us
    fly.assert.assertStr(s, "200us", 112)

    fly.os.durationFormatNsec(5, s)   // 5ns
    fly.assert.assertStr(s, "5ns", 113)

    fly.os.durationFormatNsec(0, s)   // 0s
    fly.assert.assertStr(s, "0s", 114)

    // ── timeFormatSec ─────────────────────────────────────────────────────────
    // Unix timestamp 1000000000 = 2001-09-09 01:46:40 UTC
    long epoch_ts = 1000000000
    fly.os.timeFormatSec(epoch_ts, "2006-01-02", s)
    fly.assert.assertStr(s, "2001-09-09", 140)

    fly.os.timeFormatSec(epoch_ts, "15:04:05", s)
    fly.assert.assertStr(s, "01:46:40", 141)

    fly.os.timeFormatSec(epoch_ts, "2006-01-02T15:04:05", s)
    fly.assert.assertStr(s, "2001-09-09T01:46:40", 142)

    // Unix timestamp 0 = 1970-01-01 00:00:00 UTC
    long zero_sec = 0
    fly.os.timeFormatSec(zero_sec, "2006-01-02", s)
    fly.assert.assertStr(s, "1970-01-01", 143)

    // ── timeParseToSec ────────────────────────────────────────────────────────
    long parsed_sec = 0
    fly.os.timeParseToSec("2001-09-09T01:46:40", "2006-01-02T15:04:05", parsed_sec)
    long expected_ts = 1000000000
    fly.assert.assertEqL(parsed_sec, expected_ts, 150)

    fly.os.timeParseToSec("1970-01-01", "2006-01-02", parsed_sec)
    long zero_ts = 0
    fly.assert.assertEqL(parsed_sec, zero_ts, 151)

    // ── pathGlobCount ─────────────────────────────────────────────────────────
    fly.os.fsWriteStr("/tmp/fly_os_glob_a.txt", "a", 420)
    fly.os.fsWriteStr("/tmp/fly_os_glob_b.txt", "b", 420)
    int glob_n = 0
    fly.os.pathGlobCount("/tmp/fly_os_glob_*.txt", glob_n)
    fly.assert.assertGtI(glob_n, 1, 160)
    fly.os.fsDelete("/tmp/fly_os_glob_a.txt")
    fly.os.fsDelete("/tmp/fly_os_glob_b.txt")

    // ── fsDirDeleteAll (cleanup) ──────────────────────────────────────────────
    fly.os.fsDirDeleteAll(test_dir)
    fly.os.fsExists(test_dir, b)
    fly.assert.assertFalse(b, 130)

    // ── IO class tests ─────────────────────────────────────────────────────────
    // Skipped: using fly_file/Reader/Writer as local variables from an imported
    // namespace triggers a CodeGen crash (codegen limitation with heap-allocated
    // struct/interface types from external namespaces).  The IO functions themselves
    // (fsReader, ioReadLine, ioWriteString, etc.) are implemented in os.fly and
    // are exercised end-to-end when called from within the fly.os namespace.
}
