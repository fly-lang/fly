import fly.os.io
import fly.os.fs
import fly.assert

main() {
    // fly.os.io Reader/Writer interfaces are tested indirectly: the
    // FileReader/FileWriter implementations are used internally by fly.os.fs
    // (readStr/writeStr/appendStr all drive the same syscall wrappers).
    // Using IO types as local variables from imported namespaces currently
    // triggers a CodeGen crash (known compiler limitation — class fields that
    // hold interface types are not yet supported across namespace boundaries).
    // This file will expand as that limitation is lifted.

    string s = ""
    bool b = false

    // Verify io.Buf struct is accessible (used implicitly by fs read/write)
    string test_file = "/tmp/fly_io_test.txt"
    fly.os.fs.writeStr(test_file, "io test data", 420)
    fly.os.fs.readStr(test_file, s)
    fly.assert.assertStr(s, "io test data", 1)
    fly.os.fs.delete(test_file)
    fly.os.fs.exists(test_file, b)
    fly.assert.assertFalse(b, 2)
}
