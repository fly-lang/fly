import fly.os.time
import fly.assert

void main() {
    string s = ""
    long ts = 0

    ts = time.nowSec()
    if ts <= 0 { assert.errExit(120) }

    s = time.durationFormatNsec(5405000000000)   // 1h30m5s
    assert.assertStr(s, "1h30m05s", 130)

    s = time.durationFormatNsec(500000000)   // 500ms
    assert.assertStr(s, "500ms", 131)

    s = time.durationFormatNsec(200000)   // 200us
    assert.assertStr(s, "200us", 132)

    s = time.durationFormatNsec(5)   // 5ns
    assert.assertStr(s, "5ns", 133)

    s = time.durationFormatNsec(0)   // 0s
    assert.assertStr(s, "0s", 134)

    long epoch_ts = 1000000000
    s = time.formatSec(epoch_ts, "2006-01-02")
    assert.assertStr(s, "2001-09-09", 140)

    s = time.formatSec(epoch_ts, "15:04:05")
    assert.assertStr(s, "01:46:40", 141)

    s = time.formatSec(epoch_ts, "2006-01-02T15:04:05")
    assert.assertStr(s, "2001-09-09T01:46:40", 142)

    long zero_sec = 0
    s = time.formatSec(zero_sec, "2006-01-02")
    assert.assertStr(s, "1970-01-01", 143)

    long parsed_sec = time.parseToSec("2001-09-09T01:46:40", "2006-01-02T15:04:05")
    long expected_ts = 1000000000
    assert.assertEqL(parsed_sec, expected_ts, 150)

    parsed_sec = time.parseToSec("1970-01-01", "2006-01-02")
    long zero_ts = 0
    assert.assertEqL(parsed_sec, zero_ts, 151)
}
