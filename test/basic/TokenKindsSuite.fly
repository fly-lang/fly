import fly.compiler.basic.*
import fly.compiler.ast.*
import fly.compiler.parser.*
import fly.assert

// TokenKindsSuite — token kind names, keyword recognition, enum comparison.
suite TokenKindsSuite {

    void nameTest() {
        case "names": {
            assert.assertStr(tokKindName(TokenKind.EOF), "EOF", 1)
            assert.assertStr(tokKindName(TokenKind.IDENT), "Ident", 2)
            assert.assertStr(tokKindName(TokenKind.KEYWORD), "Keyword", 3)
            assert.assertStr(tokKindName(TokenKind.NUMBER), "Number", 4)
            assert.assertStr(tokKindName(TokenKind.STRING), "String", 5)
            assert.assertStr(tokKindName(TokenKind.CHAR), "Char", 6)
            assert.assertStr(tokKindName(TokenKind.PUNCT), "Punct", 7)
            assert.assertStr(tokKindName(TokenKind.UNKNOWN), "Unknown", 8)
        }
    }

    void keywordTest() {
        case "keywords": {
            assert.assertTrue(isKeyword("class"), 9)
            assert.assertTrue(isKeyword("enum"), 10)
            assert.assertTrue(isKeyword("return"), 11)
            assert.assertFalse(isKeyword("Foo"), 12)
            assert.assertFalse(isKeyword("classy"), 13)
        }
    }

    void enumCompareTest() {
        case "equality": {
            assert.assertTrue(TokenKind.PUNCT == TokenKind.PUNCT, 14)
            assert.assertFalse(TokenKind.EOF == TokenKind.IDENT, 15)
            assert.assertTrue(TokenKind.EOF != TokenKind.IDENT, 16)
        }
    }

    // Fine-grained kinds (TokenKinds.def) used by the 1:1 parser port.
    void keywordKindTest() {
        case "getKeywordKind": {
            assert.assertTrue(getKeywordKind("namespace") == TokenKind.kw_namespace, 20)
            assert.assertTrue(getKeywordKind("class") == TokenKind.kw_class, 21)
            assert.assertTrue(getKeywordKind("while") == TokenKind.kw_while, 22)
            assert.assertTrue(getKeywordKind("int") == TokenKind.kw_int, 23)
            // non-keyword spellings resolve to identifier
            assert.assertTrue(getKeywordKind("foo") == TokenKind.identifier, 24)
            assert.assertTrue(getKeywordKind("classy") == TokenKind.identifier, 25)
        }
    }

    void punctKindTest() {
        case "getPunctKind": {
            assert.assertTrue(getPunctKind("(") == TokenKind.l_paren, 30)
            assert.assertTrue(getPunctKind("==") == TokenKind.equalequal, 31)
            assert.assertTrue(getPunctKind("<<=") == TokenKind.lesslessequal, 32)
            assert.assertTrue(getPunctKind(">>") == TokenKind.greatergreater, 33)
            assert.assertTrue(getPunctKind("&") == TokenKind.amp, 34)
            assert.assertTrue(getPunctKind("zzz") == TokenKind.unknown, 35)
        }
        case "getPunctuatorSpelling round-trips": {
            assert.assertStr(getPunctuatorSpelling(TokenKind.l_paren), "(", 36)
            assert.assertStr(getPunctuatorSpelling(TokenKind.lesslessequal), "<<=", 37)
            assert.assertStr(getPunctuatorSpelling(TokenKind.greatergreaterequal), ">>=", 38)
            assert.assertStr(getPunctuatorSpelling(TokenKind.kw_class), "", 39)
        }
    }

    void classifyTest() {
        case "isKeywordKind / isLiteralKind / getTokenName": {
            assert.assertTrue(isKeywordKind(TokenKind.kw_return), 40)
            assert.assertFalse(isKeywordKind(TokenKind.l_paren), 41)
            assert.assertFalse(isKeywordKind(TokenKind.identifier), 42)
            assert.assertTrue(isLiteralKind(TokenKind.numeric_constant), 43)
            assert.assertTrue(isLiteralKind(TokenKind.string_literal), 44)
            assert.assertFalse(isLiteralKind(TokenKind.kw_int), 45)
            assert.assertStr(getTokenName(TokenKind.kw_namespace), "kw_namespace", 46)
            assert.assertStr(getTokenName(TokenKind.l_brace), "l_brace", 47)
        }
    }
}
