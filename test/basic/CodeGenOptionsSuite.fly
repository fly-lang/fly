import fly.compiler.basic.*
import fly.compiler.ast.*
import fly.compiler.parser.*
import fly.assert
import fly.str

// CodeGenOptionsSuite — default option values, the no-builtin function list, and
// the full directly-declared field surface ported from the C++ CodeGenOptions.h.
suite CodeGenOptionsSuite {

    void defaultsTest() {
        case "defaults": {
            CodeGenOptions o = new CodeGenOptions()
            assert.assertFalse(o.isStatic, 1)
            assert.assertFalse(o.isShared, 2)
            assert.assertFalse(o.debugSymbols, 3)
            assert.assertEqI(o.optLevel, 0, 4)
            assert.assertEqI(o.jobs, 0, 5)
            assert.assertStr(o.coverageVersion, "402*", 6)
            // new-field defaults
            assert.assertStr(o.getRelocationModel(), "", 12)
            assert.assertStr(o.getFPDenormalMode(), "ieee", 13)
            assert.assertStr(o.getFP32DenormalMode(), "ieee", 14)
            assert.assertStr(o.getThreadModel(), "", 15)
            assert.assertStr(o.getMainFileName(), "", 16)
        }
    }

    void noBuiltinTest() {
        case "registration": {
            CodeGenOptions o = new CodeGenOptions()
            assert.assertFalse(o.isNoBuiltinFunc("memset"), 7)
            o.addNoBuiltinFunc("memset")
            o.addNoBuiltinFunc("memcpy")
            assert.assertTrue(o.isNoBuiltinFunc("memset"), 8)
            assert.assertTrue(o.isNoBuiltinFunc("memcpy"), 9)
            assert.assertFalse(o.isNoBuiltinFunc("printf"), 10)
            // whole-segment match only: "mem" must not match "memset"/"memcpy"
            assert.assertFalse(o.isNoBuiltinFunc("mem"), 11)
        }
    }

    void stringFieldsTest() {
        case "string + scalar setters round-trip": {
            CodeGenOptions o = new CodeGenOptions()
            o.setRelocationModel("pic")
            o.setCodeModel("large")
            o.setThreadModel("single")
            o.setOptLevel(2)
            o.setJobs(4)
            o.setDebugSymbols(true)
            o.setMainFileName("prog.fly")
            o.setFloatABI("hard")
            o.setOptRecordFormat("yaml")
            o.setOptimizationRemarkPattern("inline")
            assert.assertStr(o.getRelocationModel(), "pic", 20)
            assert.assertStr(o.getCodeModel(), "large", 21)
            assert.assertStr(o.getThreadModel(), "single", 22)
            assert.assertEqI(o.getOptLevel(), 2, 23)
            assert.assertEqI(o.getJobs(), 4, 24)
            assert.assertTrue(o.getDebugSymbols(), 25)
            assert.assertStr(o.getMainFileName(), "prog.fly", 26)
            assert.assertStr(o.getFloatABI(), "hard", 27)
            assert.assertStr(o.getOptRecordFormat(), "yaml", 28)
            assert.assertStr(o.getOptimizationRemarkPattern(), "inline", 29)
        }
    }

    void listFieldsTest() {
        case "; -delimited list fields round-trip (count via fly.str.count)": {
            CodeGenOptions o = new CodeGenOptions()
            o.addDependentLibrary("m")
            o.addDependentLibrary("pthread")
            // ";m;pthread;" → 3 ';' → 2 segments
            assert.assertEqI(fly.str.count(o.getDependentLibraries(), ";") - 1, 2, 40)
            assert.assertTrue(fly.str.contains(o.getDependentLibraries(), ";pthread;"), 41)
            o.addSanitizeRecover("address")
            assert.assertTrue(fly.str.contains(o.getSanitizeRecover(), ";address;"), 42)
            o.addPassPlugin("/tmp/p.so")
            assert.assertTrue(fly.str.contains(o.getPassPlugins(), ";/tmp/p.so;"), 43)
            o.addLinkerOption("-lfoo")
            assert.assertTrue(fly.str.contains(o.getLinkerOptions(), ";-lfoo;"), 44)
        }
    }
}
