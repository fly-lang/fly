namespace fly.compiler.codegen.test.stage5b

import fly.compiler.basic.*
import fly.compiler.ast.*
import fly.compiler.parser.*
import fly.compiler.sema.*
import fly.compiler.codegen.*
import fly.data.*
import fly.assert

// Stage 5b: single inheritance — flattened layout + single vtable per class with
// stable slots. `poke(Animal)` calls a.sound() on a base-typed receiver; passing a
// Dog must dispatch to Dog.sound (7), proving virtual dispatch (not Animal.sound=0).
// getLegs is inherited and reads the flattened `legs` field (set to 4 by Dog's
// ctor). out = 7 + 4 = 11.
void main() {
    string src = "public class Animal { int legs  public Animal() { this.legs = 4 }  public int sound() { out = 0 }  public int getLegs() { out = this.legs } }  public class Dog : Animal { public Dog() { this.legs = 4 }  public int sound() { out = 7 } }  int poke(Animal a) { out = a.sound() }  int main() { Dog d = new Dog()  int s = poke(d)  int l = d.getLegs()  out = s + l }"
    Parser p = new Parser(src)
    ASTModule m = p.parseModule("t")
    assert.assertTrue(p.isSuccess(), 1)

    List<ASTModule> mods = new List<ASTModule>()
    mods.add(m)
    SemaContext ctx = new SemaContext(null)
    List<SemaModule> res = ctx.Resolve(mods, false)
    Registry reg = ctx.getReg()

    CodeGenModule cgm = new CodeGenModule("t")
    cgm.generate(reg)

    cgm.emitIR("/tmp/cg/stage5b.ll")

    bool ok = false
    cgm.verify(ok)
    assert.assertTrue(ok, 2)
}
