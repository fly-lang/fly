namespace fly.compiler.codegen.test.driver

import fly.compiler.frontend.*
import fly.compiler.driver.*
import fly.compiler.basic.*
import fly.compiler.target.*
import fly.os.fs
import fly.str
import fly.assert

// ─────────────────────────────────────────────────────────────────────────────
// CodeGenDriverSuite — the compiler front (CompilerInstance + Frontend + Driver),
// exercised IN-PROCESS. A program is fed through a CompilerInstance (the C++ CI
// model): build FrontendOptions/CodeGenOptions/TargetOptions, register the source
// buffer, then Frontend.execute() parses → resolves → codegens → emits. Covers a
// valid program → exit 0 + emitted IR; a malformed one → exit 1; --no-output →
// exit 0 + no file; the Driver output-path / module-name helpers.
//
// NOTE: clang-link + run + exit-code (old driver_test.sh) can't run in a suite (no
// process-exec / JIT) — replaced by asserting the emitted IR content. CI setup is
// inlined per case (a suite helper returning a value crashes the reference
// compiler).
// ─────────────────────────────────────────────────────────────────────────────

suite CodeGenDriverSuite {

    void compileTest() {
        case "valid program → exit 0 + .ll emitted with IR": {
            FrontendOptions fo = new FrontendOptions("/tmp/cg/drv.ll")
            fo.setBackendAction(0)                     // emit LLVM IR
            CodeGenOptions cgo = new CodeGenOptions()
            TargetOptions to = new TargetOptions("x86_64-unknown-linux-gnu")
            CompilerInstance ci = new CompilerInstance(null, fo, cgo, to)
            ci.createSourceManager("t", "int main() { out = 42 }")
            Frontend fe = new Frontend(ci)
            int code = fe.execute("", false)
            assert.assertEqI(code, 0, 1)
            assert.assertTrue(fly.os.fs.exists("/tmp/cg/drv.ll"), 2)
            string ir = fly.os.fs.readStr("/tmp/cg/drv.ll")
            assert.assertTrue(fly.str.contains(ir, "define"), 3)
            assert.assertTrue(fly.str.contains(ir, "store i32 42"), 4)
        }
        case "malformed program → exit 1": {
            FrontendOptions fo = new FrontendOptions("/tmp/cg/bad.ll")
            fo.setBackendAction(0)
            CodeGenOptions cgo = new CodeGenOptions()
            TargetOptions to = new TargetOptions("x86_64-unknown-linux-gnu")
            CompilerInstance ci = new CompilerInstance(null, fo, cgo, to)
            ci.createSourceManager("t", "int main( { out =")
            Frontend fe = new Frontend(ci)
            int code = fe.execute("", false)
            assert.assertEqI(code, 1, 11)
        }
        case "--no-output → exit 0 + no file written": {
            fly.os.fs.delete("/tmp/cg/noout.ll")
            FrontendOptions fo = new FrontendOptions("/tmp/cg/noout.ll")
            fo.setBackendAction(0)
            CodeGenOptions cgo = new CodeGenOptions()
            TargetOptions to = new TargetOptions("x86_64-unknown-linux-gnu")
            CompilerInstance ci = new CompilerInstance(null, fo, cgo, to)
            ci.createSourceManager("t", "int main() { out = 1 }")
            Frontend fe = new Frontend(ci)
            int code = fe.execute("", true)
            assert.assertEqI(code, 0, 21)
            assert.assertTrue(fly.os.fs.exists("/tmp/cg/noout.ll") == false, 22)
        }
    }

    void pathTest() {
        case "Driver output-path + module-name helpers": {
            Driver d = new Driver()
            assert.assertStr(d.defaultOut("foo.fly"), "foo.ll", 31)
            assert.assertStr(d.defaultOut("bar.txt"), "bar.txt.ll", 32)
            assert.assertStr(d.moduleName("foo.fly"), "foo", 33)
        }
        case "--out-dir prefixes relative paths, leaves absolute/empty alone": {
            Driver d = new Driver()
            assert.assertStr(d.applyOutDir("/tmp/od", "sub.ll"), "/tmp/od/sub.ll", 41)
            assert.assertStr(d.applyOutDir("", "x.ll"), "x.ll", 42)
            assert.assertStr(d.applyOutDir("/tmp/od", "/abs.ll"), "/abs.ll", 43)
        }
    }

    void optionsTest() {
        case "-v / --test options don't change a successful compile": {
            FrontendOptions fo = new FrontendOptions("/tmp/cg/opt.ll")
            fo.setBackendAction(0)
            fo.setVerbose(true)
            fo.setTestMode(true)
            CodeGenOptions cgo = new CodeGenOptions()
            TargetOptions to = new TargetOptions("x86_64-unknown-linux-gnu")
            CompilerInstance ci = new CompilerInstance(null, fo, cgo, to)
            ci.createSourceManager("t", "int main() { out = 1 }")
            Frontend fe = new Frontend(ci)
            int code = fe.execute("", false)
            assert.assertEqI(code, 0, 51)
        }
    }
}
