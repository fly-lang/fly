namespace fly.compiler.codegen.test.stage6

import fly.compiler.basic.*
import fly.compiler.ast.*
import fly.compiler.parser.*
import fly.compiler.sema.*
import fly.compiler.codegen.*
import fly.data.*
import fly.assert

// Stage 6 enums (now Sema-resolvable): each entry lowers to its i32 index; enum
// vars are i32. classify compares the enum against entry constants (RED=1,
// GREEN=2, BLUE=3). c = BLUE → 33. out = 33.
void main() {
    string src = "public enum Color { RED, GREEN, BLUE }  int classify(const Color c) { int r = 11  if c == Color.GREEN { r = 22 } elsif c == Color.BLUE { r = 33 }  out = r }  int main() { Color c = Color.BLUE  out = classify(c) }"
    Parser p = new Parser(src)
    ASTModule m = p.parseModule("t")
    assert.assertTrue(p.isSuccess(), 1)

    List<ASTModule> mods = new List<ASTModule>()
    mods.add(m)
    SemaContext ctx = new SemaContext(null)
    List<SemaModule> res = ctx.Resolve(mods, false)
    Registry reg = ctx.getReg()

    CodeGenModule cgm = new CodeGenModule("t")
    cgm.generate(reg)

    cgm.emitIR("/tmp/cg/stage6.ll")

    bool ok = false
    cgm.verify(ok)
    assert.assertTrue(ok, 2)
}
