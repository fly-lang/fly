namespace fly.compiler.codegen.test.stage2

import fly.compiler.basic.*
import fly.compiler.ast.*
import fly.compiler.parser.*
import fly.compiler.sema.*
import fly.compiler.codegen.*
import fly.data.*
import fly.assert

// Stage 2: expressions — binary arith, comparison, and a cast, with parameter
// operands (so the IR shows real load/add/icmp/sext instructions).
void main() {
    string src = "int add(const int a, const int b) { out = a + b }  bool gt(const int a, const int b) { out = a > b }  long widen(const int n) { out = (long) n }"
    Parser p = new Parser(src)
    ASTModule m = p.parseModule("t")
    assert.assertTrue(p.isSuccess(), 1)

    List<ASTModule> mods = new List<ASTModule>()
    mods.add(m)
    SemaContext ctx = new SemaContext(null)
    List<SemaModule> res = ctx.Resolve(mods, false)
    Registry reg = ctx.getReg()

    CodeGenModule cgm = new CodeGenModule("t")
    cgm.generate(reg)

    bool ok = false
    cgm.verify(ok)
    assert.assertTrue(ok, 2)

    cgm.emitIR("/tmp/cg/stage2.ll")
}
