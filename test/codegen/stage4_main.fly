namespace fly.compiler.codegen.test.stage4

import fly.compiler.basic.*
import fly.compiler.ast.*
import fly.compiler.parser.*
import fly.compiler.sema.*
import fly.compiler.codegen.*
import fly.data.*
import fly.assert

// Stage 4: functions + calls + the C-ABI main wrapper. A multi-function program
// with a plain call (add), recursion (fact), control flow, and an `int main`
// whose `out` becomes the process exit code (42). Emits IR + verifies; the
// milestone_test.sh harness clang-links the .ll and asserts the exit code.
void main() {
    string src = "int add(const int a, const int b) { out = a + b }  int fact(const int n) { if n <= 1 { out = 1 } else { out = n * fact(n - 1) } }  int main() { int s = add(40, 2)  int f = fact(4)  out = s }"
    Parser p = new Parser(src)
    ASTModule m = p.parseModule("t")
    assert.assertTrue(p.isSuccess(), 1)

    List<ASTModule> mods = new List<ASTModule>()
    mods.add(m)
    SemaContext ctx = new SemaContext(null)
    List<SemaModule> res = ctx.Resolve(mods, false)
    Registry reg = ctx.getReg()

    CodeGenModule cgm = new CodeGenModule("t")
    cgm.generate(reg)

    cgm.emitIR("/tmp/cg/stage4.ll")

    bool ok = false
    cgm.verify(ok)
    assert.assertTrue(ok, 2)
}
