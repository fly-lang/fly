namespace fly.compiler.codegen.test.stage5

import fly.compiler.basic.*
import fly.compiler.ast.*
import fly.compiler.parser.*
import fly.compiler.sema.*
import fly.compiler.codegen.*
import fly.data.*
import fly.assert

// Stage 5a: a single class — struct layout (vtable ptr + fields), a constructor
// with params, a method, `new` (malloc + vtable store + ctor call), member access
// (this.x / this.y), and virtual dispatch (p.sum() through the vtable). main
// returns 42; milestone_test.sh clang-links the .ll and asserts the exit code.
void main() {
    string src = "public class Point { int x  int y  public Point(int a, int b) { this.x = a  this.y = b }  public int sum() { out = this.x + this.y } }  int main() { Point p = new Point(40, 2)  int s = p.sum()  out = s }"
    Parser p = new Parser(src)
    ASTModule m = p.parseModule("t")
    assert.assertTrue(p.isSuccess(), 1)

    List<ASTModule> mods = new List<ASTModule>()
    mods.add(m)
    SemaContext ctx = new SemaContext(null)
    List<SemaModule> res = ctx.Resolve(mods, false)
    Registry reg = ctx.getReg()

    CodeGenModule cgm = new CodeGenModule("t")
    cgm.generate(reg)

    cgm.emitIR("/tmp/cg/stage5.ll")

    bool ok = false
    cgm.verify(ok)
    assert.assertTrue(ok, 2)
}
