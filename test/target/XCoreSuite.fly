namespace fly.compiler.target.test.xcore

import fly.compiler.target.*
import fly.assert

suite XCoreSuite {

    void metadataTest() {
        case "xcore (32, i64 aligned to 32)": {
            assert.assertTrue(archFromName("xcore") == Arch.XCORE, 1)
            TargetInfo a = targetInfoCreate(new TargetOptions("xcore-unknown-unknown"))
            assert.assertStr(a.getDataLayout(), "e-m:e-p:32:32-i1:8:32-i8:8:32-i16:16:32-i64:32-f64:32-a:0:32-n32", 2)
            assert.assertEqI(a.getPointerWidth(), 32, 3)
            assert.assertFalse(a.isBigEndian(), 4)
        }
    }

    void machineTest() {
        case "xcore target machine": {
            assert.assertTrue(targetMachineCheck("xcore-unknown-unknown", Arch.XCORE) != 2, 5)
        }
    }
}
