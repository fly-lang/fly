namespace fly.compiler.target.test.ptrsize

import fly.compiler.basic.*
import fly.compiler.ast.*
import fly.compiler.parser.*
import fly.compiler.sema.*
import fly.compiler.codegen.*
import fly.compiler.target.*
import fly.data.*
import fly.assert
import fly.os.fs
import fly.str

// ─────────────────────────────────────────────────────────────────────────────
// PtrSizeWidthSuite — ptrsize is the pointer-sized unsigned integer: it lowers to
// the TARGET pointer width, while long stays a fixed 64-bit type on every target.
// Proven by emitting the same source for x86_64 (64-bit) and riscv32 (32-bit) and
// inspecting the integer widths in the IR.
// ─────────────────────────────────────────────────────────────────────────────

// cgIRTarget — compile `src` for `triple` and return the emitted LLVM IR text.
public string cgIRTarget(const string src, const string triple) {
    Parser p = new Parser(src)
    ASTModule m = p.parseModule("t")
    assert.assertTrue(p.isSuccess(), 90)
    List<ASTModule> mods = new List<ASTModule>()
    mods.add(m)
    SemaContext ctx = new SemaContext(null)
    List<SemaModule> res = ctx.Resolve(mods, false)
    CodeGenModule cgm = new CodeGenModule("t")
    TargetInfo ti = targetInfoCreate(new TargetOptions(triple))
    cgm.configureTarget(ti)              // sets pointer width for ptrsize
    cgm.generate(ctx.getReg())
    bool ok = false
    cgm.verify(ok)
    assert.assertTrue(ok, 91)
    cgm.emitIR("/tmp/cg/ptrsize.ll")
    out = fly.os.fs.readStr("/tmp/cg/ptrsize.ll")
}

suite PtrSizeWidthSuite {

    void widthTest() {
        case "ptrsize = i64 on x86_64, i32 on riscv32; long stays i64": {
            string src = "ptrsize uid(const ptrsize a) { out = a }  long lid(const long a) { out = a }"
            string ir64 = cgIRTarget(src, "x86_64-unknown-linux-gnu")
            string ir32 = cgIRTarget(src, "riscv32-unknown-linux-gnu")

            // x86_64: ptrsize and long both i64; no i32 integer load present.
            assert.assertTrue(fly.str.contains(ir64, "load i64"), 1)
            assert.assertFalse(fly.str.contains(ir64, "load i32"), 2)

            // riscv32: ptrsize became i32, but long is STILL i64 (fixed-width).
            assert.assertTrue(fly.str.contains(ir32, "load i32"), 3)
            assert.assertTrue(fly.str.contains(ir32, "load i64"), 4)
        }
    }
}
