namespace fly.compiler.target.test.amdgpu

import fly.compiler.target.*
import fly.assert

suite AMDGPUSuite {

    void metadataTest() {
        case "amdgcn (64) / r600 (32)": {
            assert.assertTrue(archFromName("amdgcn") == Arch.AMDGCN, 1)
            TargetInfo a = targetInfoCreate(new TargetOptions("amdgcn-amd-amdhsa"))
            assert.assertStr(a.getDataLayout(), "e-p:64:64-p1:64:64-p2:32:32-p3:32:32-p4:64:64-p5:32:32-p6:32:32-p7:160:256:256:32-p8:128:128:128:48-p9:192:256:256:32-i64:64-v16:16-v24:32-v32:32-v48:64-v96:128-v192:256-v256:256-v512:512-v1024:1024-v2048:2048-n32:64-S32-A5-G1-ni:7:8:9", 2)
            assert.assertEqI(a.getPointerWidth(), 64, 3)
            assert.assertTrue(archFromName("r600") == Arch.R600, 4)
            TargetInfo b = targetInfoCreate(new TargetOptions("r600-unknown-unknown"))
            assert.assertStr(b.getDataLayout(), "e-p:32:32-i64:64-v16:16-v24:32-v32:32-v48:64-v96:128-v192:256-v256:256-v512:512-v1024:1024-v2048:2048-n32:64-S32-A5-G1", 5)
            assert.assertEqI(b.getPointerWidth(), 32, 6)
        }
    }

    void machineTest() {
        case "amdgcn target machine": {
            assert.assertTrue(targetMachineCheck("amdgcn-amd-amdhsa", Arch.AMDGCN) != 2, 7)
        }
    }
}
