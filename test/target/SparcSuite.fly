namespace fly.compiler.target.test.sparc

import fly.compiler.target.*
import fly.assert

suite SparcSuite {

    void metadataTest() {
        case "sparc (BE 32) / sparcv9 (BE 64)": {
            assert.assertTrue(archFromName("sparc") == Arch.SPARC, 1)
            TargetInfo a = targetInfoCreate(new TargetOptions("sparc-unknown-linux-gnu"))
            assert.assertStr(a.getDataLayout(), "E-m:e-p:32:32-i64:64-i128:128-f128:64-n32-S64", 2)
            assert.assertEqI(a.getPointerWidth(), 32, 3)
            assert.assertTrue(a.isBigEndian(), 4)
            assert.assertTrue(archFromName("sparcv9") == Arch.SPARCV9, 5)
            TargetInfo b = targetInfoCreate(new TargetOptions("sparcv9-unknown-linux-gnu"))
            assert.assertStr(b.getDataLayout(), "E-m:e-i64:64-i128:128-n32:64-S128", 6)
            assert.assertEqI(b.getPointerWidth(), 64, 7)
            assert.assertTrue(b.isBigEndian(), 8)
        }
    }

    void machineTest() {
        case "sparc target machine": {
            assert.assertTrue(targetMachineCheck("sparc-unknown-linux-gnu", Arch.SPARC) != 2, 9)
        }
    }
}
