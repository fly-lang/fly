namespace fly.compiler.target.test.ve

import fly.compiler.target.*
import fly.assert

suite VESuite {

    void metadataTest() {
        case "ve (64)": {
            assert.assertTrue(archFromName("ve") == Arch.VE, 1)
            TargetInfo a = targetInfoCreate(new TargetOptions("ve-unknown-unknown"))
            assert.assertStr(a.getDataLayout(), "e-m:e-i64:64-n32:64-S128-v64:64:64-v128:64:64-v256:64:64-v512:64:64-v1024:64:64-v2048:64:64-v4096:64:64-v8192:64:64-v16384:64:64", 2)
            assert.assertEqI(a.getPointerWidth(), 64, 3)
            assert.assertFalse(a.isBigEndian(), 4)
        }
    }

    void machineTest() {
        case "ve target machine": {
            assert.assertTrue(targetMachineCheck("ve-unknown-unknown", Arch.VE) != 2, 5)
        }
    }
}
