import fly.compiler.basic.*
import fly.compiler.ast.*
import fly.compiler.parser.*
import fly.data.*
import fly.assert

// Modifiers on top-level and member declarations.
suite ParserModifierSuite {
    void modifierTest() {
        case "public static int f()": {
            Parser p = new Parser("public static int f() { out = 1 }")
            ASTModule m = p.parseModule("t")
            assert.assertTrue(p.isSuccess(), 1)
        }
        case "private/protected members": {
            Parser p = new Parser("class C { private int a  protected string s  public C() { } }")
            ASTModule m = p.parseModule("t")
            assert.assertTrue(p.isSuccess(), 2)
        }
        case "final abstract class": {
            Parser p = new Parser("public abstract class Base { public int x }")
            ASTModule m = p.parseModule("t")
            assert.assertTrue(p.isSuccess(), 3)
        }
    }
}
