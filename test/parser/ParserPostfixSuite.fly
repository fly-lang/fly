import fly.compiler.basic.*
import fly.compiler.ast.*
import fly.compiler.parser.*
import fly.data.*
import fly.assert

// Postfix: member-access chains and 'new' expressions.
suite ParserPostfixSuite {
    void memberTest() {
        case "a.b.c": {
            Parser p = new Parser("a.b.c")
            ASTExpr e = p.parseExpr()
            assert.assertTrue(p.isSuccess(), 1)
            assert.assertTrue(e != null, 2)
        }
        case "method chain": {
            Parser p = new Parser("obj.a.b().c(1)")
            ASTExpr e = p.parseExpr()
            assert.assertTrue(p.isSuccess(), 3)
        }
    }
    void newTest() {
        case "new Foo(1, 2)": {
            Parser p = new Parser("new Foo(1, 2)")
            ASTExpr e = p.parseExpr()
            assert.assertTrue(p.isSuccess(), 4)
            assert.assertTrue(e != null, 5)
        }
    }
}
