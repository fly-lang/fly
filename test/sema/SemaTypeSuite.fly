import fly.compiler.sema.*
import fly.assert

// ─────────────────────────────────────────────────────────────────────────────
// SemaTypeSuite — Stage 2: the builtin/array/type-param hierarchy. Predicates,
// ranks, signedness, name-based equality.
// ─────────────────────────────────────────────────────────────────────────────

suite SemaTypeSuite {

    void builtinTest() {
        case "bool / void / string / error / complex predicates": {
            SemaBoolType b = new SemaBoolType()
            assert.assertTrue(b.isBool(), 1)
            assert.assertTrue(b.isNumber() == false, 2)
            assert.assertStr(b.getName(), "bool", 3)
            assert.assertTrue(b.getKind() == SemaKind.TYPE_BOOL, 4)

            SemaVoidType v = new SemaVoidType()
            assert.assertTrue(v.isVoid(), 5)
            SemaStringType st = new SemaStringType()
            assert.assertTrue(st.isString(), 6)
            SemaErrorType e = new SemaErrorType()
            assert.assertTrue(e.isError(), 7)
            SemaComplexType c = new SemaComplexType()
            assert.assertTrue(c.isComplex(), 8)
        }
    }

    void intTest() {
        case "int kinds: rank, signedness, predicates": {
            SemaIntType i = new SemaIntType(SemaIntTypeKind.TYPE_INT, "int")
            assert.assertTrue(i.isInteger(), 10)
            assert.assertTrue(i.isNumber(), 11)
            assert.assertEqI(i.getRank(), 31, 12)
            assert.assertTrue(i.isSigned(), 13)
            assert.assertTrue(i.getIntKind() == SemaIntTypeKind.TYPE_INT, 14)

            SemaIntType u = new SemaIntType(SemaIntTypeKind.TYPE_UINT, "uint")
            assert.assertEqI(u.getRank(), 32, 15)
            assert.assertTrue(u.isUnsigned(), 16)

            SemaIntType by = new SemaIntType(SemaIntTypeKind.TYPE_BYTE, "byte")
            assert.assertEqI(by.getRank(), 8, 17)
            assert.assertTrue(by.isUnsigned(), 18)

            SemaIntType lo = new SemaIntType(SemaIntTypeKind.TYPE_LONG, "long")
            assert.assertEqI(lo.getRank(), 63, 19)
            assert.assertTrue(lo.isSigned(), 20)
        }
    }

    void floatTest() {
        case "float kinds: rank outranks ints": {
            SemaFloatType f = new SemaFloatType(SemaFloatTypeKind.TYPE_FLOAT, "float")
            assert.assertTrue(f.isFloat(), 30)
            assert.assertTrue(f.isNumber(), 31)
            assert.assertEqI(f.getRank(), 320, 32)
            SemaFloatType d = new SemaFloatType(SemaFloatTypeKind.TYPE_DOUBLE, "double")
            assert.assertEqI(d.getRank(), 640, 33)
            assert.assertTrue(d.getFloatKind() == SemaFloatTypeKind.TYPE_DOUBLE, 34)
        }
    }

    void equalsTest() {
        case "name-based type identity": {
            SemaIntType i1 = new SemaIntType(SemaIntTypeKind.TYPE_INT, "int")
            SemaIntType i2 = new SemaIntType(SemaIntTypeKind.TYPE_INT, "int")
            SemaIntType lo = new SemaIntType(SemaIntTypeKind.TYPE_LONG, "long")
            assert.assertTrue(i1.isEquals(i2), 40)
            assert.assertTrue(i1.isEquals(lo) == false, 41)
            assert.assertTrue(i1.isEquals(null) == false, 42)
        }
    }

    void arrayAndParamTest() {
        case "array element type + type param bound": {
            SemaIntType elem = new SemaIntType(SemaIntTypeKind.TYPE_INT, "int")
            SemaArrayType arr = new SemaArrayType(elem, 8)
            assert.assertTrue(arr.isArray(), 50)
            assert.assertEqI((int)arr.getSize(), 8, 51)
            SemaType et = arr.getElementType()
            assert.assertTrue(et.isInteger(), 52)

            SemaTypeParam tp = new SemaTypeParam("T")
            assert.assertTrue(tp.getKind() == SemaKind.TYPE_PARAM, 53)
            assert.assertStr(tp.getName(), "T", 54)
            assert.assertTrue(tp.isClass() == false, 55)
            assert.assertTrue(tp.getBound() == null, 56)
            tp.setBound(elem)
            SemaType bd = tp.getBound()
            assert.assertTrue(bd.isInteger(), 57)
        }
    }
}
